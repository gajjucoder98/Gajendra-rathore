<section class="custom-product-cards">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="section-heading">{{ section.settings.heading }}</h2>
    {% endif %}
 
    <div class="product-cards-grid">
      {% for block in section.blocks %}
        {% assign product = block.settings.product %}
 
        {% if product != blank %}
          <div class="product-card" {{ block.shopify_attributes }}>
            <div class="product-card__image">
              {% if block.settings.custom_image != blank %}
                {{ block.settings.custom_image | image_url: width: 800 | image_tag: loading: 'lazy' }}
              {% elsif product.featured_image %}
                {{ product.featured_image | image_url: width: 800 | image_tag: loading: 'lazy' }}
              {% endif %}
            </div>
 
            <div class="product-card__overlay">
              <div class="product-card__content">
                <div class="product-info-top">
                  <div class="product-thumb">
                    {% if product.featured_image %}
                      {{ product.featured_image | image_url: width: 200 | image_tag: loading: 'lazy' }}
                    {% endif %}
                  </div>
 
                  <div class="product-details">
                    <h3>{{ block.settings.custom_title | default: product.title }}</h3>
 
                    <div class="product-desc">
                      {{ block.settings.custom_description | default: product.description | strip_html | truncate: 70 }}
                    </div>
 
                    <div class="product-price js-product-price">
                      {{ product.price | money }}
                    </div>
 
                    <div class="product-vendor">
                      {{ product.vendor }}
                    </div>
                  </div>
                </div>
 
                {% if product.has_only_default_variant == false %}
                  <div class="variant-selection-wrapper">
                    <select class="variant-select color-select">
                      {% assign unique_colors = "" %}
                      {% for variant in product.variants %}
                        {% unless unique_colors contains variant.option1 %}
                          <option value="{{ variant.option1 }}">{{ variant.option1 }}</option>
                          {% assign unique_colors = unique_colors | append: variant.option1 | append: "," %}
                        {% endunless %}
                      {% endfor %}
                    </select>
 
                    <select class="variant-select size-select">
                      {% assign unique_sizes = "" %}
                      {% for variant in product.variants %}
                        {% unless unique_sizes contains variant.option2 %}
                          <option value="{{ variant.option2 }}">{{ variant.option2 }}</option>
                          {% assign unique_sizes = unique_sizes | append: variant.option2 | append: "," %}
                        {% endunless %}
                      {% endfor %}
                    </select>
                  </div>
 
                  <script type="application/json" class="variants-data">
                    [
                      {% for variant in product.variants %}
                        {
                          "id": {{ variant.id }},
                          "color": {{ variant.option1 | json }},
                          "size": {{ variant.option2 | json }},
                          "price": {{ variant.price | money | json }}
                        }{% unless forloop.last %},{% endunless %}
                      {% endfor %}
                    ]
                  </script>
                {% else %}
                  <script type="application/json" class="variants-data">
                    [
                      {
                        "id": {{ product.selected_or_first_available_variant.id }},
                        "color": "",
                        "size": "",
                        "price": {{ product.price | money | json }}
                      }
                    ]
                  </script>
                {% endif %}
 
                <button
                  type="button"
                  class="product-btn custom-add-to-cart"
                  data-product-id="{{ product.id }}"
                >
                  Add To Cart
                </button>
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
 
<script>
document.addEventListener('DOMContentLoaded', function() {
 
  // जब यूज़र ड्रॉपडाउन बदलेगा तो प्राइस अपडेट करने के लिए फंक्शन
  function updateVariantPrice(card) {
    const colorSelect = card.querySelector('.color-select');
    const sizeSelect = card.querySelector('.size-select');
    const variantsDataEl = card.querySelector('.variants-data');
    const priceDisplay = card.querySelector('.js-product-price');
 
    if (!variantsDataEl || !priceDisplay) return;
 
    const variants = JSON.parse(variantsDataEl.textContent);
    if (!colorSelect || !sizeSelect) return;
 
    const selectedColor = colorSelect.value;
    const selectedSize = sizeSelect.value;
 
    const matchedVariant = variants.find(
      (variant) => variant.color === selectedColor && variant.size === selectedSize
    );
 
    if (matchedVariant) {
      priceDisplay.textContent = matchedVariant.price;
    }
  }
 
  // ड्रॉपडाउन चेंज इवेंट पर प्राइस अपडेट करना
  document.addEventListener('change', function(e) {
    if (e.target.classList.contains('color-select') || e.target.classList.contains('size-select')) {
      const card = e.target.closest('.product-card');
      updateVariantPrice(card);
    }
  });
 
  // एड टू कार्ट और कार्ट रिफ्रेश फंक्शनलिटी
  document.addEventListener('click', async function (e) {
    if (!e.target.classList.contains('custom-add-to-cart')) return;
 
    const button = e.target;
    const card = button.closest('.product-card');
 
    let variantId = null;
    let selectedColor = '';
    let selectedSize = '';
 
    const colorSelect = card.querySelector('.color-select');
    const sizeSelect = card.querySelector('.size-select');
    const variantsDataEl = card.querySelector('.variants-data');
 
    if (variantsDataEl) {
      const variants = JSON.parse(variantsDataEl.textContent);
 
      if (colorSelect && sizeSelect) {
        selectedColor = colorSelect.value;
        selectedSize = sizeSelect.value;
 
        const matchedVariant = variants.find(
          (variant) => variant.color === selectedColor && variant.size === selectedSize
        );
 
        if (matchedVariant) {
          variantId = matchedVariant.id;
        }
      } else {
        variantId = variants[0].id;
      }
    }
 
    if (!variantId) {
      alert('This combination is not available. Please select another one.');
      return;
    }
 
    button.disabled = true;
    button.textContent = 'Adding...';
 
    try {
      const response = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: 1 }),
      });
 
      if (!response.ok) throw new Error('Add to cart failed');
      const data = await response.json();
 
      const FREE_VARIANT_ID = 43383113613379;
 
      // गिफ्ट लॉजिक (Black + M होने पर)
      if (selectedColor.toLowerCase() === 'black' && selectedSize.toLowerCase() === 'm') {
        await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: FREE_VARIANT_ID, quantity: 1 }),
        });
      }
 
      button.textContent = 'Added ✓';
 
      // --- कार्ट और हेडर डॉट/काउंटर अपडेट करने का लॉजिक ---
     
      // 1. स्टैंडर्ड Shopify थीम्स (जैसे Dawn) के लिए रिफ्रेश इवेंट
      if (window.sections && window.sections.renderBySectionId) {
        window.sections.renderBySectionId('cart-icon-bubble');
      }
     
      // 2. पब्लिक पब्लिश-सब्सक्राइब (PubSub) इवेंट्स ट्रिगर करना
      if (window.Shopify && window.Shopify.pubsub) {
        window.Shopify.pubsub.publish('cart-updated', {});
      }
 
      // 3. कार्ट काउंट को JSON से लाइव फ़ेच करके अपडेट करना (बैकअप तरीका)
      const cartRes = await fetch('/cart.js');
      const cartData = await cartRes.json();
     
      // हेडर में कार्ट बबल/डॉट ढूंढ कर अपडेट करना
      const cartBubbles = document.querySelectorAll('.cart-count-bubble, #cart-icon-bubble, .cart-link__count');
      cartBubbles.forEach(bubble => {
        if (cartData.item_count > 0) {
          // अगर डॉट/काउंटर पहले से छुपा है तो उसे दिखाएँ
          bubble.style.display = 'block';
          bubble.classList.remove('hidden');
         
          // काउंटर के अंदर की संख्या बदलें
          const countSpan = bubble.querySelector('span:not(.visually-hidden)') || bubble;
          if (countSpan) countSpan.textContent = cartData.item_count;
        }
      });
 
      // कस्टम इवेंट (अगर आपकी थीम में कोई अन्य स्क्रिप्ट इसे सुन रही हो)
      document.dispatchEvent(new CustomEvent('custom:cart-updated'));
      document.dispatchEvent(new CustomEvent('cart:refresh'));
 
      setTimeout(() => {
        button.textContent = 'Add To Cart';
        button.disabled = false;
      }, 1500);
 
    } catch (error) {
      console.error(error);
      button.textContent = 'Error';
      setTimeout(() => {
        button.textContent = 'Add To Cart';
        button.disabled = false;
      }, 1500);
    }
  });
});
</script>
 
 
<style>
      .custom-product-cards {
        padding: 60px 0;
      }
 
      .section-heading {
        text-align: center;
        margin-bottom: 40px;
      }
 
      .product-cards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(280px,1fr));
        gap: 24px;
      }
  .product-info-top{
    display:flex;
    align-items:flex-start;
    gap:16px;
    margin-bottom:20px;
    text-align:left;
  }
 
  .product-thumb{
    width:90px;
    min-width:90px;
  }
 
  .product-thumb img{
    width:100%;
    height:90px;
    object-fit:cover;
    border-radius:8px;
    display:block;
  }
 
  .product-details{
    flex:1;
  }
 
  .product-details h3{
    margin:0 0 8px;
    color:#fff;
    font-size:20px;
    line-height:1.2;
  }
 
  .product-desc{
    color:#ddd;
    font-size:13px;
    line-height:1.4;
    margin-bottom:10px;
  }
 
  .product-price{
    color:#fff;
    font-size:18px;
    font-weight:700;
    margin-bottom:6px;
  }
 
  .product-vendor{
    color:#cfcfcf;
    font-size:13px;
  }
 
  .variant-selection-wrapper {
    display: flex;
    gap: 10px;
    margin-bottom: 12px;
  }
 
  .variant-select{
    width:100%;
    padding: 12px;
    border-radius: 8px;
    border: none;
    background: #fff;
    color: #000;
  }
 
  .product-btn{
    width:100%;
  }
      .product-card {
      position: relative;
      overflow: hidden;
      border-radius: 16px;
      height: 500px;
    }
 
    .product-card__image,
    .product-card__image img {
      width: 100%;
      height: 100%;
    }
 
    .product-card__image img {
      object-fit: cover;
      display: block;
      transition: transform .5s ease;
    }
 
    .product-card__overlay {
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,.75);
 
      display: flex;
      align-items: center;
      justify-content: center;
 
      padding: 25px;
 
      opacity: 0;
      visibility: hidden;
 
      transition: all .35s ease;
    }
 
    .product-card:hover .product-card__overlay {
      opacity: 1;
      visibility: visible;
    }
 
    .product-card:hover img {
      transform: scale(1.08);
    }
 
    .product-card__content {
      text-align: center;
      color: #fff;
      width: 100%;
    }
 
    .product-card__content h3 {
      color: #fff;
      margin-bottom: 12px;
      font-size: 24px;
    }
 
    .product-desc {
      margin-bottom: 18px;
      line-height: 1.6;
      font-size: 14px;
    }
 
    .product-btn {
      width: 100%;
      padding: 14px;
      border: none;
      border-radius: 8px;
      background: #fff;
      color: #000;
      font-weight: 600;
      cursor: pointer;
      transition: .3s;
    }
 
    .product-btn:hover {
      transform: translateY(-2px);
    }
 
    @media screen and (max-width: 768px) {
      .product-card__overlay {
        opacity: 1;
        visibility: visible;
        background: linear-gradient(
          to top,
          rgba(0,0,0,.85),
          rgba(0,0,0,.4)
        );
      }
    }
</style>
 
{% schema %}
{
  "name": "Custom Product Cards",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Image"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom Title"
        },
        {
          "type": "textarea",
          "id": "custom_description",
          "label": "Custom Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Product Cards",
      "blocks": [
        {
          "type": "product_card"
        },
        {
          "type": "product_card"
        }
      ]
    }
  ]
}
{% endschema %}