<section class="custom-product-cards">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="section-heading">{{ section.settings.heading }}</h2>
    {% endif %}
 
    <div class="product-cards-grid">
      {% for block in section.blocks %}
        {% assign product = block.settings.product %}
        {% if product != blank %}
          
          <div class="product-card" data-block-id="{{ block.id }}">
            <div class="product-card__image">
              {% if block.settings.custom_image != blank %}
                {{ block.settings.custom_image | image_url: width: 800 | image_tag: loading: 'lazy' }}
              {% elsif product.featured_image %}
                {{ product.featured_image | image_url: width: 800 | image_tag: loading: 'lazy' }}
              {% endif %}
            </div>
            <div class="product-card__plus-icon" style="top: {{ block.settings.icon_top }}%; left: {{ block.settings.icon_left }}%;">
              <span class="plus-symbol">+</span>
            </div>

            <!-- POPUP MODAL (Every Product has its own isolated HTML structure) -->
            <div class="ppc-popup-backdrop js-popup-backdrop">
              <div class="ppc-popup" onclick="event.stopPropagation();">
                <button type="button" class="ppc-popup__close js-popup-close">&times;</button>

                <div class="ppc-popup__body">
                  <div class="product-info-top">
                    <div class="product-thumb">
                      {% if product.featured_image %}{{ product.featured_image | image_url: width: 200 | image_tag }}{% endif %}
                    </div>
                    <div class="product-details">
                      <h3>{{ block.settings.custom_title | default: product.title }}</h3>
                      <div class="product-desc">{{ block.settings.custom_description | default: product.description | strip_html | truncate: 120 }}</div>
                      <div class="product-price js-price-display">{{ product.price | money }}</div>
                      <div class="product-vendor">{{ product.vendor }}</div>
                    </div>
                  </div>

                  <!-- Dynamic UI Option Groups -->
                  <div class="variant-selection-container">
                    {% unless product.has_only_default_variant %}
                      {% for option in product.options_with_values %}
                        <div class="variant-option-group">
                          <label class="variant-label">{{ option.name }}</label>
                          
                          {% if option.name == 'Color' or option.name == 'color' or option.name == 'Colour' %}
                            <div class="color-swatch-wrapper">
                              {% for value in option.values %}
                                <div class="color-swatch-item">
                                  <input type="radio" id="opt-{{ block.id }}-{{ forloop.parentloop.index0 }}-{{ forloop.index0 }}" name="color-{{ block.id }}" value="{{ value | escape }}" class="color-swatch-input js-option-selector" data-index="option{{ forloop.parentloop.index }}" {% if forloop.first %}checked{% endif %}>
                                  <label for="opt-{{ block.id }}-{{ forloop.parentloop.index0 }}-{{ forloop.index0 }}" class="color-swatch-label">{{ value }}</label>
                                </div>
                              {% endfor %}
                            </div>
                          {% else %}
                            <div class="size-dropdown-wrapper">
                              <select class="variant-select js-option-selector" data-index="option{{ forloop.index }}">
                                <option value="" disabled selected>Choose {{ option.name }}</option>
                                {% for value in option.values %}
                                  <option value="{{ value | escape }}">{{ value }}</option>
                                {% endfor %}
                              </select>
                              <span class="dropdown-chevron"><svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none"><polyline points="6 9 12 15 18 9"></polyline></svg></span>
                            </div>
                          {% endif %}
                        </div>
                      {% endfor %}
                    {% endunless %}
                  </div>

                  <!-- HIDDEN ACTUAL NATIVE MASTER SELECT FOR VARIANT ID -->
                  <select class="js-master-id-select" name="id" style="display: none;">
                    {% for variant in product.variants %}
                      <option value="{{ variant.id }}" 
                        data-price="{{ variant.price | money }}"
                        data-available="{{ variant.available }}"
                        data-option1="{{ variant.option1 | escape }}"
                        data-option2="{{ variant.option2 | escape }}"
                        data-option3="{{ variant.option3 | escape }}"
                        {% if variant == product.selected_or_first_available_variant %}selected="selected"{% endif %}>
                        {{ variant.title }}
                      </option>
                    {% endfor %}
                  </select>

                  <button type="button" class="product-btn js-add-to-cart">
                    <span>ADD TO CART</span>
                    <span class="btn-arrow">→</span>
                  </button>
                </div>
              </div>
            </div>

          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function () {

  // 1. OPEN / CLOSE POPUP ACTIONS
  document.querySelectorAll('.product-card').forEach(card => {
    card.addEventListener('click', () => {
      card.querySelector('.js-popup-backdrop').classList.add('active');
      document.body.style.overflow = 'hidden';
    });
  });

  document.querySelectorAll('.js-popup-close, .js-popup-backdrop').forEach(closeTarget => {
    closeTarget.addEventListener('click', function (e) {
      e.stopPropagation();
      this.closest('.js-popup-backdrop').classList.remove('active');
      document.body.style.overflow = '';
    });
  });

  // 2. VARIANT SELECTION & VALUE PICKER LOGIC
  document.querySelectorAll('.product-card').forEach(card => {
    const masterSelect = card.querySelector('.js-master-id-select');
    if (!masterSelect) return;

    card.addEventListener('change', function (e) {
      if (!e.target.classList.contains('js-option-selector')) return;

      // Current User Selection collect krna
      const radioChecked = card.querySelector('.color-swatch-input:checked');
      const dropdownSelect = card.querySelector('.variant-select');

      const val1 = radioChecked ? radioChecked.value.toLowerCase().trim() : '';
      const val2 = dropdownSelect ? dropdownSelect.value.toLowerCase().trim() : '';

      // Master select options me se perfect matching row dhundna
      let matchedOption = null;
      Array.from(masterSelect.options).forEach(opt => {
        const o1 = (opt.dataset.option1 || '').toLowerCase().trim();
        const o2 = (opt.dataset.option2 || '').toLowerCase().trim();

        // Shopify dynamic check configuration
        if ((o1 === val1 && o2 === val2) || (o1 === val2 && o2 === val1) || (!o2 && (o1 === val1 || o1 === val2))) {
          matchedOption = opt;
        }
      });

      // Agar match mil gya to master select value update kardo and price badlo
      if (matchedOption) {
        masterSelect.value = matchedOption.value;
        card.querySelector('.js-price-display').textContent = matchedOption.dataset.price;
      }
    });
  });

  // 3. CART PUSH & CONDITIONAL FREE GIFT RULE
  document.querySelectorAll('.js-add-to-cart').forEach(btn => {
    btn.addEventListener('click', async function (e) {
      e.stopPropagation();
      const card = this.closest('.product-card');
      const masterSelect = card.querySelector('.js-master-id-select');
      const selectedOption = masterSelect.options[masterSelect.selectedIndex];

      // Safe checks
      const sizeDropdown = card.querySelector('.variant-select');
      if (sizeDropdown && !sizeDropdown.value) {
        alert('Please select a size first!');
        return;
      }

      if (selectedOption.dataset.available === 'false') {
        alert('This variant is currently Out of Stock!');
        return;
      }

      // ── Step A: Get Selected Variant ID ──
      const activeVariantId = Number(masterSelect.value);
      const itemsPayload = [{ id: activeVariantId, quantity: 1 }];

      // ── Step B: Check Rule Condition (Color: Black & Size: M) ──
      const radioChecked = card.querySelector('.color-swatch-input:checked');
      const colorValue = radioChecked ? radioChecked.value.toLowerCase().trim() : '';
      const sizeValue = sizeDropdown ? sizeDropdown.value.toLowerCase().trim() : '';

      if (colorValue === 'black' && sizeValue === 'm') {
        const FREE_GIFT_VARIANT_ID = 8565446934713;
        console.log('[CartAPI] Gift match rule success! Pushing Free Product ID.');
        itemsPayload.push({ id: Number(FREE_GIFT_VARIANT_ID), quantity: 1 });
      }

      // ── Step C: Push Array to /cart/add.js ──
      btn.disabled = true;
      this.querySelector('span').textContent = 'ADDING...';

      try {
        const response = await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: itemsPayload })
        });

        if (!response.ok) throw new Error('Add Failed');

        this.querySelector('span').textContent = 'ADDED ✓';
        card.querySelector('.js-popup-backdrop').classList.remove('active');
        document.body.style.overflow = '';

        // ── Step D: Open Theme Cart Drawer ──
        triggerCartDrawerOpen();

      } catch (err) {
        console.error('[CartAPI] Process Interrupted:', err);
        this.querySelector('span').textContent = 'TRY AGAIN';
      } finally {
        setTimeout(() => {
          btn.disabled = false;
          this.querySelector('span').textContent = 'ADD TO CART';
        }, 1500);
      }
    });
  });

  // 4. THEME DRAWER REFRESH & OPEN HANDLER (Isolated)
  async function triggerCartDrawerOpen() {
    const themeDrawer = document.querySelector('cart-drawer');
    if (!themeDrawer) return;

    try {
      // Cart Bubble update krna aur Drawer sections fresh hit krna
      const refreshRes = await fetch('/?sections=cart-drawer,cart-icon-bubble');
      const sectionData = await refreshRes.json();
      
      if (typeof themeDrawer.renderContents === 'function') {
        themeDrawer.renderContents({ sections: sectionData });
      } else if (typeof themeDrawer.open === 'function') {
        themeDrawer.open();
      }
    } catch (e) {
      // Backup simple execution style
      if (typeof themeDrawer.open === 'function') themeDrawer.open();
    }
  }

});
</script>
 
<style>
  /* ═══════════════════════════════════════════════════════════════════════════
     STRUCTURE STYLES
     ═══════════════════════════════════════════════════════════════════════════ */
  .custom-product-cards { padding: 60px 0; }
  .section-heading { text-align: center; margin-bottom: 40px; }
  .product-cards-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px; }

  .product-card { position: relative; overflow: hidden; border-radius: 16px; height: 520px; cursor: pointer; }
  .product-card__image, .product-card__image img { width: 100%; height: 100%; }
  .product-card__image img { object-fit: cover; display: block; transition: transform .5s ease; }
  .product-card:hover img { transform: scale(1.06); }

  .product-card__plus-icon {
    position: absolute; transform: translate(-50%, -50%); width: 36px; height: 36px;
    background: #ffffff; border-radius: 50%; display: flex; align-items: center; justify-content: center;
    box-shadow: 0 4px 14px rgba(0,0,0,0.25); z-index: 2; pointer-events: none; transition: all 0.35s ease;
  }
  .product-card:hover .product-card__plus-icon { transform: translate(-50%, -50%) scale(1.25); box-shadow: 0 6px 22px rgba(0,0,0,0.35); }
  .plus-symbol { color: #000000; font-size: 22px; font-weight: bold; line-height: 1; }

  /* ═══════════════════════════════════════════════════════════════════════════
     POPUP CARDS ELEMENTS
     ═══════════════════════════════════════════════════════════════════════════ */
  .ppc-popup-backdrop {
    position: fixed; inset: 0; z-index: 9999; background: rgba(0, 0, 0, 0);
    display: flex; align-items: center; justify-content: center; visibility: hidden; transition: all 0.35s ease;
  }
  .ppc-popup-backdrop.active { background: rgba(0, 0, 0, 0.65); visibility: visible; }

  .ppc-popup {
    position: relative; background: #1a1a1a; color: #fff; border-radius: 20px;
    max-width: 480px; width: 92%; max-height: 90vh; overflow-y: auto; padding: 32px 28px 28px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.55), 0 0 0 1px rgba(255,255,255,0.08);
    transform: translateY(40px) scale(0.95); opacity: 0; transition: all 0.35s cubic-bezier(.22,.61,.36,1); cursor: default;
  }
  .ppc-popup-backdrop.active .ppc-popup { transform: translateY(0) scale(1); opacity: 1; }

  .ppc-popup__close {
    position: absolute; top: 12px; right: 14px; background: rgba(255,255,255,0.1); border: none;
    color: #fff; font-size: 26px; width: 36px; height: 36px; border-radius: 50%; cursor: pointer;
    display: flex; align-items: center; justify-content: center; transition: background 0.2s; line-height: 1;
  }
  .ppc-popup__close:hover { background: rgba(255,255,255,0.25); }

  .product-info-top { display: flex; align-items: flex-start; gap: 16px; margin-bottom: 24px; text-align: left; }
  .product-thumb { width: 90px; min-width: 90px; }
  .product-thumb img { width: 100%; height: 90px; object-fit: cover; border-radius: 10px; display: block; }
  .product-details { flex: 1; }
  .product-details h3 { margin: 0 0 8px; color: #fff; font-size: 20px; line-height: 1.2; }
  .product-desc { color: #bbb; font-size: 13px; line-height: 1.5; margin-bottom: 10px; }
  .product-price { color: #fff; font-size: 18px; font-weight: 700; margin-bottom: 6px; }
  .product-vendor { color: #999; font-size: 13px; }

  .variant-selection-container { text-align: left; margin-bottom: 24px; }
  .variant-option-group { margin-bottom: 16px; }
  .variant-label { display: block; font-size: 14px; color: #fff; margin-bottom: 8px; font-weight: 500; }
  
  .color-swatch-wrapper { display: flex; border: 1px solid rgba(255, 255, 255, 0.25); border-radius: 8px; overflow: hidden; }
  .color-swatch-item { flex: 1; text-align: center; position: relative; border-right: 1px solid rgba(255, 255, 255, 0.25); }
  .color-swatch-item:last-child { border-right: none; }
  .color-swatch-input { position: absolute; opacity: 0; cursor: pointer; height: 0; width: 0; }
  .color-swatch-label { display: block; padding: 12px; background: transparent; color: #fff; font-size: 15px; cursor: pointer; transition: all 0.2s; }
  .color-swatch-input:checked + .color-swatch-label { background: #ffffff; color: #000000; font-weight: bold; }

  .size-dropdown-wrapper { position: relative; width: 100%; }
  .variant-select { width: 100%; padding: 14px 40px 14px 16px; border-radius: 8px; border: 1px solid rgba(255, 255, 255, 0.25); background: transparent; color: #fff; font-size: 15px; appearance: none; -webkit-appearance: none; cursor: pointer; }
  .variant-select option { background: #1a1a1a; color: #fff; }
  .dropdown-chevron { position: absolute; right: 16px; top: 50%; transform: translateY(-50%); color: #fff; pointer-events: none; display: flex; align-items: center; }

  .product-btn { width: 100%; padding: 16px 24px; border: 1px solid #ffffff; background: #000000; color: #ffffff; font-size: 16px; font-weight: bold; letter-spacing: 1px; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 12px; border-radius: 10px; transition: all 0.3s ease; }
  .product-btn:hover:not(:disabled) { background: #fff; color: #000; }
  .product-btn:disabled { opacity: 0.7; cursor: not-allowed; }
  .btn-arrow { font-size: 20px; line-height: 1; transition: transform 0.2s; }
  .product-btn:hover:not(:disabled) .btn-arrow { transform: translateX(4px); }

  @media screen and (max-width: 768px) {
    .product-card__plus-icon { width: 32px; height: 32px; }
    .ppc-popup { max-width: 96%; padding: 24px 20px 20px; border-radius: 16px; }
  }
</style>
 
{% schema %}
{
  "name": "Custom Product Cards",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Image"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom Title"
        },
        {
          "type": "textarea",
          "id": "custom_description",
          "label": "Custom Description"
        },
        {
          "type": "header",
          "content": "Plus Icon Position"
        },
        {
          "type": "range",
          "id": "icon_top",
          "min": 5,
          "max": 95,
          "step": 1,
          "unit": "%",
          "label": "Icon Position (Top)",
          "default": 30
        },
        {
          "type": "range",
          "id": "icon_left",
          "min": 5,
          "max": 95,
          "step": 1,
          "unit": "%",
          "label": "Icon Position (Left)",
          "default": 65
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Product Cards",
      "blocks": [
        { "type": "product_card" },
        { "type": "product_card" }
      ]
    }
  ]
}
{% endschema %}