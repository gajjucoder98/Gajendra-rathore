<section class="custom-product-cards">
  <div class="custom-product-inner">
    {% if section.settings.heading != blank %}
      <h2 class="section-heading">{{ section.settings.heading }}</h2>
    {% endif %}
 
    <div class="product-cards-grid">
      {% for block in section.blocks %}
        {% assign product = block.settings.product %}
        {% if product != blank %}
          <div class="product-card" data-block-id="{{ block.id }}">
            <div class="product-card__image">
              {% if block.settings.custom_image != blank %}
                {{ block.settings.custom_image | image_url: width: 800 | image_tag: loading: 'lazy' }}
              {% elsif product.featured_image %}
                {{ product.featured_image | image_url: width: 800 | image_tag: loading: 'lazy' }}
              {% endif %}
            </div>
            <div
              class="product-card__plus-icon"
              style="top: {{ block.settings.icon_top }}%; left: {{ block.settings.icon_left }}%;"
            >
              {% render 'plus-icon' %}
            </div>

            <div class="ppc-popup-backdrop js-popup-backdrop">
              <div class="ppc-popup" onclick="event.stopPropagation();">
                <button type="button" class="ppc-popup__close js-popup-close">&times;</button>

                <div class="ppc-popup__body">
                  <div class="product-info-top">
                    <div class="product-thumb">
                      {% if product.featured_image -%}
                        {{- product.featured_image | image_url: width: 200 | image_tag -}}
                      {%- endif %}
                    </div>
                    <div class="product-details">
                      <h3>{{ block.settings.custom_title | default: product.title }}</h3>
                      <div class="product-desc">
                        {{
                          block.settings.custom_description
                          | default: product.description
                          | strip_html
                          | truncate: 120
                        }}
                      </div>
                      <div class="product-price js-price-display">{{ product.price | money }}</div>
                   
                    </div>
                  </div>

                  <div class="variant-selection-container">
                    {% unless product.has_only_default_variant %}
                      {% for option in product.options_with_values %}
                        <div class="variant-option-group">
                          <label class="variant-label">{{ option.name }}</label>
                          {% if option.name == 'Color' or option.name == 'color' or option.name == 'Colour' %}
                            <div class="color-swatch-wrapper">
                              {% for value in option.values %}
                                <div class="color-swatch-item">
                                  <input
                                    type="radio"
                                    id="opt-{{ block.id }}-{{ forloop.parentloop.index0 }}-{{ forloop.index0 }}"
                                    name="color-{{ block.id }}"
                                    value="{{ value | escape }}"
                                    class="color-swatch-input js-option-selector"
                                    {% if forloop.first %}
                                      checked
                                    {% endif %}
                                  >
                                  <label
                                    for="opt-{{ block.id }}-{{ forloop.parentloop.index0 }}-{{ forloop.index0 }}"
                                    class="color-swatch-label"
                                    style="--swatch-color: {{ value.swatch.color }};"

                                  >
                                    {{- value -}}
                                  </label>
                                </div>
                              {% endfor %}
                            </div>
                          {% else %}
                            <div class="size-dropdown-wrapper">
                              <select class="variant-select js-option-selector">
                                <option value="" disabled selected>Choose {{ option.name }}</option>
                                {% for value in option.values %}
                                  <option value="{{ value | escape }}">{{ value }}</option>
                                {% endfor %}
                              </select>
                              <span class="dropdown-chevron">
                                <svg
                                  viewBox="0 0 24 24"
                                  width="18"
                                  height="18"
                                  stroke="currentColor"
                                  stroke-width="2"
                                  fill="none"
                                >
                                  <polyline points="6 9 12 15 18 9"></polyline>
                                </svg>
                              </span>
                            </div>
                          {% endif %}
                        </div>
                      {% endfor %}
                    {% endunless %}
                  </div>

                  <button type="button" class="product-btn js-add-to-cart">
                    <span>ADD TO CART</span>
                    <span class="btn-arrow">→</span>
                  </button>
                </div>
              </div>
            </div>

            <script class="js-raw-product-data" type="application/json">
              {
                "variants": [
                  {% for variant in product.variants %}
                    {
                      "id": {{ variant.id }},
                      "price": {{ variant.price | money | json }},
                      "available": {{ variant.available }},
                      "options": {{ variant.options | json }}
                    }{% unless forloop.last %},{% endunless %}
                  {% endfor %}
                ]
              }
            </script>

          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function () {

  // Format Helper
  function cleanVal(str) {
    return (str || '').toLowerCase().trim();
  }

  // 1. OPEN / CLOSE POPUP ACTIONS
  document.querySelectorAll('.product-card').forEach((card) => {
    const plusIcon = card.querySelector('.product-card__plus-icon');
    if (plusIcon) {
      plusIcon.addEventListener('click', (e) => {
        e.stopPropagation();
        card.querySelector('.js-popup-backdrop').classList.add('active');
        document.body.style.overflow = 'hidden';
      });
    }
  });

  document.querySelectorAll('.js-popup-close, .js-popup-backdrop').forEach((closeTarget) => {
    closeTarget.addEventListener('click', function (e) {
      e.stopPropagation();
      this.closest('.js-popup-backdrop').classList.remove('active');
      document.body.style.overflow = '';
    });
  });

  // 2. HELPER FUNCTION TO FIND ACTIVE VARIANT OBJECT FROM HTML
  function getSelectedVariant(card) {
    const jsonEl = card.querySelector('.js-raw-product-data');
    if (!jsonEl) return null;

    const productData = JSON.parse(jsonEl.textContent);
    const radioChecked = card.querySelector('.color-swatch-input:checked');
    const dropdownSelect = card.querySelector('.variant-select');

    const val1 = radioChecked ? cleanVal(radioChecked.value) : '';
    const val2 = dropdownSelect ? cleanVal(dropdownSelect.value) : '';

    return (
      productData.variants.find((variant) => {
        const vOpts = variant.options.map((o) => cleanVal(o));
        if (val1 && val2) {
          return vOpts.includes(val1) && vOpts.includes(val2);
        }
        return vOpts.includes(val1) || vOpts.includes(val2);
      }) || productData.variants[0]
    );
  }

  // 3. OPTION CHANGED & PRICE LIVE UPDATE
  document.querySelectorAll('.product-card').forEach((card) => {
    card.addEventListener('change', function (e) {
      if (!e.target.classList.contains('js-option-selector')) return;
      const matchedVariant = getSelectedVariant(card);
      if (matchedVariant) {
        card.querySelector('.js-price-display').textContent = matchedVariant.price;
      }
    });
  });

  // 4. AJAX SUBMIT AND GIFT VALIDATION
  document.querySelectorAll('.js-add-to-cart').forEach((btn) => {
    btn.addEventListener('click', async function (e) {
      e.stopPropagation();
      const card = this.closest('.product-card');
      const sizeDropdown = card.querySelector('.variant-select');

      if (sizeDropdown && !sizeDropdown.value) {
        alert('Please select a size first!');
        return;
      }

      const matchedVariant = getSelectedVariant(card);
      if (!matchedVariant) {
        alert('Combination not available!');
        return;
      }

      if (!matchedVariant.available) {
        alert('This variant is currently Out of Stock!');
        return;
      }

      const itemsPayload = [{ id: Number(matchedVariant.id), quantity: 1 }];

      // Gift rule condition
      const radioChecked = card.querySelector('.color-swatch-input:checked');
      const colorValue = radioChecked ? cleanVal(radioChecked.value) : '';
      const sizeValue = sizeDropdown ? cleanVal(sizeDropdown.value) : '';

      if (colorValue === 'black' && sizeValue === 'm') {
        const FREE_GIFT_VARIANT_ID = 47592268398777;
        console.log('[CartAPI] Gift condition matching perfectly!');
        itemsPayload.push({ id: Number(FREE_GIFT_VARIANT_ID), quantity: 1 });
      }

      btn.disabled = true;
      btn.querySelector('span').textContent = 'ADDING...';

      try {
        const response = await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: itemsPayload }),
        });

        if (!response.ok) throw new Error('API Rejection');

        btn.querySelector('span').textContent = 'ADDED ✓';
        card.querySelector('.js-popup-backdrop').classList.remove('active');
        document.body.style.overflow = '';

        await triggerCartDrawerOpen();

      } catch (err) {
        console.error('[CartAPI] Exception handling triggered:', err);
        btn.querySelector('span').textContent = 'TRY AGAIN';
      } finally {
        setTimeout(() => {
          btn.disabled = false;
          btn.querySelector('span').textContent = 'ADD TO CART';
        }, 1500);
      }
    });
  });

  // 5. DAWN THEME - CART DRAWER OPEN - FIXED
  async function triggerCartDrawerOpen() {
    try {
      const refreshRes = await fetch('/?sections=cart-drawer,cart-icon-bubble');
      const sectionData = await refreshRes.json();

      const cartDrawerEl = document.querySelector('cart-drawer');

      if (cartDrawerEl && sectionData['cart-drawer']) {
        const parsed = new DOMParser()
          .parseFromString(sectionData['cart-drawer'], 'text/html');

        const newCartDrawer = parsed.querySelector('cart-drawer');
        if (newCartDrawer) {
          cartDrawerEl.innerHTML = newCartDrawer.innerHTML;
        }

        // is-empty remove karo - yahi main issue thi
        cartDrawerEl.classList.remove('is-empty');
        cartDrawerEl.classList.add('animate', 'active');
        cartDrawerEl.removeAttribute('aria-hidden');
      }

      // Overlay active karo
      const overlay = document.querySelector('#CartDrawer-Overlay');
      if (overlay) overlay.classList.add('active');

      document.body.classList.add('overflow-hidden');

      // Cart bubble / count update
      const bubbleEl = document.querySelector('#cart-icon-bubble');
      if (bubbleEl && sectionData['cart-icon-bubble']) {
        bubbleEl.innerHTML = new DOMParser()
          .parseFromString(sectionData['cart-icon-bubble'], 'text/html')
          .querySelector('#cart-icon-bubble').innerHTML;
      }

    } catch (e) {
      console.error('[CartDrawer] Error:', e);
      const cartDrawerEl = document.querySelector('cart-drawer');
      if (cartDrawerEl) {
        cartDrawerEl.classList.remove('is-empty');
        cartDrawerEl.classList.add('animate', 'active');
        cartDrawerEl.removeAttribute('aria-hidden');
      }
    }
  }

});
</script>
 
<style>
  /* ═══════════════════════════════════════════════════════════════════════════
     STRUCTURE STYLES
     ═══════════════════════════════════════════════════════════════════════════ */
  .custom-product-cards {
     padding: 60px 0;
   }
  .section-heading {
     margin-bottom: 40px;
     font-size:36px;
     font-family:lustria;
    }
    .custom-product-inner{
      padding:0px 40px;
    }
  .product-cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 24px;
  }
  .color-swatch-label::before{
     content: '';
    width: 6px;
    height: 100%;
    /* border-radius: 50%; */
    background: var(--swatch-color);
    /* border: 1px solid #ddd; */
    flex-shrink: 0;
    display: block;
    left: 0;
    position: absolute;
    top: 0;
}

  .product-card {
     position: relative;
     overflow: hidden;
     height: 444px;

  }
  .product-card__image,
  .product-card__image img{
     width: 100%;
    height: 100%;
  }
  .product-card__image img {
    object-fit: cover;
    display: block;
    transition: transform .5s ease;
   }


  .product-card__plus-icon {
    position: absolute;
    transform: translate(-50%, -50%);
     width: 22px;
    height: 22px;
    background: #F8F8F8;
     border-radius: 50%;
     display: flex;
      align-items: center;
       justify-content: center;
    box-shadow: 0 4px 14px rgba(0,0,0,0.25);
     z-index: 2;
     cursor:pointer;
      transition: all 0.35s ease;
  }
  

  /* ═══════════════════════════════════════════════════════════════════════════
     POPUP CARDS ELEMENTS
     ═══════════════════════════════════════════════════════════════════════════ */
  .ppc-popup-backdrop {
    position: fixed; inset: 0; z-index: 9999; background: rgba(0, 0, 0, 0);
    display: flex; align-items: center; justify-content: center; visibility: hidden; transition: all 0.35s ease;
  }
  .ppc-popup-backdrop.active { background: rgba(0, 0, 0, 0.65); visibility: visible; }

  .ppc-popup {
    position: relative; background: #fff; color: #fff; 
    max-width: 400px; width: 92%; max-height: 90vh; overflow-y: auto; padding: 32px 28px 28px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.55), 0 0 0 1px rgba(255,255,255,0.08);
    transform: translateY(40px) scale(0.95); opacity: 0; transition: all 0.35s cubic-bezier(.22,.61,.36,1); cursor: default;
  }
  .ppc-popup-backdrop.active .ppc-popup { transform: translateY(0) scale(1); opacity: 1; }

  .ppc-popup__close {
        position: absolute;
    top: 12px;
    right: 14px;
    background: transparent;
    border: none;
    font-size: 26px;
    cursor: pointer;
  }
  .ppc-popup__close:hover { background: rgba(255,255,255,0.25); }

  .product-info-top { display: grid; grid-template-columns:1fr 1fr; align-items: flex-start; gap: 16px; margin-bottom: 24px; text-align: left; }
  .product-thumb{height:100%;}
  .product-thumb img { width: 100%;height:100%  object-fit: cover;  display: block; }
  .product-details { flex: 1; }
  .product-details h3 { margin: 0 0 8px; color: #000; font-size: 16px; line-height: 1.2; font-weight:200;}
  .product-desc {color: #000;
    font-size: 14px;
    line-height: 1.2;
    margin-bottom: 10px;
    letter-spacing: 0px;
    font-weight: 200;}
  .product-price { color: #000; font-size: 16px; font-weight: 400; margin-bottom: 6px;font-family:lustria }


  .variant-selection-container { text-align: left; margin-bottom: 24px; }
  .variant-option-group { margin-bottom: 16px; }
  .variant-label { display: block; font-size: 14px; color: #000; margin-bottom: 8px; font-weight: 500; }
  
  .color-swatch-wrapper { display: flex; border: 1px solid #000; overflow: hidden; }
  .color-swatch-item { flex: 1; text-align: center; position: relative; border-right: 1px solid #000; }
  .color-swatch-item:last-child { border-right: none; }
  .color-swatch-input { position: absolute; opacity: 0; cursor: pointer; height: 0; width: 0; }
  .color-swatch-label { position:relative;display: block; padding: 4px 12px; background: transparent; color: #000; font-size: 18px; cursor: pointer; transition: all 0.2s; }
  .color-swatch-input:checked + .color-swatch-label { position:relative;background: #000; color: #fff; font-weight: bold; }

  .size-dropdown-wrapper { position: relative; width: 100%; }
  .variant-select { width: 100%; padding: 14px 40px 14px 16px;  border: 1px solid #000; background: transparent; color: #000; font-size: 15px; appearance: none; -webkit-appearance: none; cursor: pointer; }
  .variant-select option { background: #fff; color: #000; }
  .dropdown-chevron { position: absolute; right: 16px; top: 50%; transform: translateY(-50%); color: #fff; pointer-events: none; display: flex; align-items: center; }

  .product-btn { width: 100%; padding: 16px 24px; border: 1px solid #ffffff; background: #000000; color: #ffffff; font-size: 16px; font-weight: bold; letter-spacing: 1px; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 12px;  transition: all 0.3s ease; }
  .product-btn:hover:not(:disabled) { background: #fff; color: #000; }
  .product-btn:disabled { opacity: 0.7; cursor: not-allowed; }
  .btn-arrow { font-size: 20px; line-height: 1; transition: transform 0.2s; }


  @media screen and (max-width: 768px) {
    .product-card__plus-icon { width: 32px; height: 32px; }
    .ppc-popup { max-width: 96%; padding: 24px 20px 20px; border-radius: 16px; }
  }
</style>
 
{% schema %}
{
  "name": "Custom Product Cards",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Image"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom Title"
        },
        {
          "type": "textarea",
          "id": "custom_description",
          "label": "Custom Description"
        },
        {
          "type": "header",
          "content": "Plus Icon Position"
        },
        {
          "type": "range",
          "id": "icon_top",
          "min": 5,
          "max": 95,
          "step": 1,
          "unit": "%",
          "label": "Icon Position (Top)",
          "default": 30
        },
        {
          "type": "range",
          "id": "icon_left",
          "min": 5,
          "max": 95,
          "step": 1,
          "unit": "%",
          "label": "Icon Position (Left)",
          "default": 65
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Product Cards",
      "blocks": [{ "type": "product_card" }, { "type": "product_card" }]
    }
  ]
}
{% endschema %}
