<section class="custom-product-cards">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="section-heading">{{ section.settings.heading }}</h2>
    {% endif %}
 
    <div class="product-cards-grid">
      {% for block in section.blocks %}
        {% assign product = block.settings.product %}
 
        {% if product != blank %}
          <div class="product-card" {{ block.shopify_attributes }}>
            <div class="product-card__image">
              {% if block.settings.custom_image != blank %}
                {{ block.settings.custom_image | image_url: width: 800 | image_tag: loading: 'lazy' }}
              {% elsif product.featured_image %}
                {{ product.featured_image | image_url: width: 800 | image_tag: loading: 'lazy' }}
              {% endif %}
            </div>

            <div class="product-card__plus-icon" style="top: {{ block.settings.icon_top }}%; left: {{ block.settings.icon_left }}%;">
              <span class="plus-symbol">+</span>
            </div>
 
            <div class="product-card__overlay">
              <div class="product-card__content">
                <div class="product-info-top">
                  <div class="product-thumb">
                    {% if product.featured_image %}
                      {{ product.featured_image | image_url: width: 200 | image_tag: loading: 'lazy' }}
                    {% endif %}
                  </div>
 
                  <div class="product-details">
                    <h3>{{ block.settings.custom_title | default: product.title }}</h3>
 
                    <div class="product-desc">
                      {{ block.settings.custom_description | default: product.description | strip_html | truncate: 70 }}
                    </div>
 
                    <div class="product-price js-product-price">
                      {{ product.price | money }}
                    </div>
 
                    <div class="product-vendor">
                      {{ product.vendor }}
                    </div>
                  </div>
                </div>
 
                {% if product.has_only_default_variant == false %}
                  <div class="variant-selection-container">
                    
                    {% comment %} Color Swatches Block {% endcomment %}
                    <div class="variant-option-group">
                      <label class="variant-label">Color</label>
                      <div class="color-swatch-wrapper">
                        {% assign unique_colors = "" %}
                        {% assign color_index = 0 %}
                        {% for variant in product.variants %}
                          {% unless unique_colors contains variant.option1 %}
                            <div class="color-swatch-item">
                              <input 
                                type="radio" 
                                id="color-{{ block.id }}-{{ forloop.index }}" 
                                name="color-{{ block.id }}" 
                                value="{{ variant.option1 }}" 
                                class="color-swatch-input"
                                {% if color_index == 0 %}checked{% endif %}
                              >
                              <label for="color-{{ block.id }}-{{ forloop.index }}" class="color-swatch-label">
                                {{ variant.option1 }}
                              </label>
                            </div>
                            {% assign unique_colors = unique_colors | append: variant.option1 | append: "," %}
                            {% assign color_index = color_index | add: 1 %}
                          {% endunless %}
                        {% endfor %}
                      </div>
                    </div>

                    {% comment %} Size Dropdown Block {% endcomment %}
                    <div class="variant-option-group">
                      <label class="variant-label">Size</label>
                      <div class="size-dropdown-wrapper">
                        <select class="variant-select size-select">
                          <option value="" disabled selected>Choose your size</option>
                          {% assign unique_sizes = "" %}
                          {% for variant in product.variants %}
                            {% unless unique_sizes contains variant.option2 %}
                              <option value="{{ variant.option2 }}">{{ variant.option2 }}</option>
                              {% assign unique_sizes = unique_sizes | append: variant.option2 | append: "," %}
                            {% endunless %}
                          {% endfor %}
                        </select>
                        <span class="dropdown-chevron">
                          <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                        </span>
                      </div>
                    </div>

                  </div>
 
                  <script type="application/json" class="variants-data">
                    [
                      {% for variant in product.variants %}
                        {
                          "id": {{ variant.id }},
                          "color": {{ variant.option1 | json }},
                          "size": {{ variant.option2 | json }},
                          "price": {{ variant.price | money | json }},
                          "available": {{ variant.available | json }}
                        }{% unless forloop.last %},{% endunless %}
                      {% endfor %}
                    ]
                  </script>
                {% else %}
                  <script type="application/json" class="variants-data">
                    [
                      {
                        "id": {{ product.selected_or_first_available_variant.id }},
                        "color": "",
                        "size": "",
                        "price": {{ product.price | money | json }},
                        "available": {{ product.selected_or_first_available_variant.available | json }}
                      }
                    ]
                  </script>
                {% endif %}
 
                <button
                  type="button"
                  class="product-btn custom-add-to-cart"
                  data-product-id="{{ product.id }}"
                >
                  <span>ADD TO CART</span>
                  <span class="btn-arrow">→</span>
                </button>
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
 
<script>
document.addEventListener('DOMContentLoaded', function () {

  // ─── Helpers ────────────────────────────────────────────────────────────────

  function normalize(str) {
    return (str || '').trim().toLowerCase();
  }

  function getVariants(card) {
    const el = card.querySelector('.variants-data');
    if (!el) return [];
    try { return JSON.parse(el.textContent); } catch (e) { return []; }
  }

  function getSelectedColor(card) {
    const checked = card.querySelector('.color-swatch-input:checked');
    return checked ? checked.value : '';
  }

  function getSelectedSize(card) {
    const select = card.querySelector('.size-select');
    return select ? select.value : '';
  }

  function findVariant(variants, color, size) {
    if (color && size) {
      return variants.find(
        v => normalize(v.color) === normalize(color) &&
             normalize(v.size)  === normalize(size)
      ) || null;
    }
    if (size) {
      return variants.find(v => normalize(v.size) === normalize(size)) || null;
    }
    return variants[0] || null;
  }

  // ─── Price update ────────────────────────────────────────────────────────────

  function updatePrice(card) {
    const priceDisplay = card.querySelector('.js-product-price');
    if (!priceDisplay) return;

    const variants = getVariants(card);
    const color    = getSelectedColor(card);
    const size     = getSelectedSize(card);

    if (card.querySelector('.size-select') && !size) return;

    const matched = findVariant(variants, color, size);
    if (matched) priceDisplay.textContent = matched.price;
  }

  // ─── Cart count update ───────────────────────────────────────────────────────

  async function refreshCartCount() {
    try {
      const res   = await fetch('/cart.js');
      const cart  = await res.json();
      const count = cart.item_count;

      document.querySelectorAll('.cart-count-bubble, #cart-icon-bubble, .cart-link__count').forEach(bubble => {
        if (count > 0) {
          bubble.removeAttribute('hidden');
          bubble.classList.remove('hidden');
        } else {
          bubble.setAttribute('hidden', '');
        }
        const spans = bubble.querySelectorAll('span[aria-hidden="true"], span:not(.visually-hidden)');
        spans.forEach(span => { span.textContent = count; });
      });

      document.dispatchEvent(new CustomEvent('cart:refresh'));
      document.dispatchEvent(new CustomEvent('custom:cart-updated'));

      if (window.Shopify && window.Shopify.sections) {
        window.Shopify.sections.load('#cart-icon-bubble').catch(() => {});
      }
    } catch (e) {
      console.warn('[ProductCards] Cart count refresh failed:', e);
    }
  }

  // ─── Drawer open + Shopify Section Rendering API se update ──────────────────

  async function openCartDrawer() {
    const drawer = document.querySelector('.drawer__inner');
    console.log(drawer)

    // Step 1: Active class add karo — CSS me transform: translate(0) is pe lagega
    if (drawer) {
      drawer.classList.add('active');
    }

    // Step 2: Shopify Section Rendering API se drawer ka fresh HTML fetch karo
    try {
      // Cart drawer ka section ID dhundo page pe
      const sectionEl = document.querySelector('[id^="shopify-section"][id*="cart"]');
      const sectionId = sectionEl
        ? sectionEl.id.replace('shopify-section-', '')
        : 'cart-drawer'; // agar nahi mila toh default fallback

      const res  = await fetch(`/?sections=${sectionId}`);
      const data = await res.json();

      if (data[sectionId]) {
        const parser     = new DOMParser();
        const newDoc     = parser.parseFromString(data[sectionId], 'text/html');
        const newDrawer  = newDoc.querySelector('.drawer__inner');

        if (drawer && newDrawer) {
          // Inner HTML replace karo — active class wapas lagao kyunki innerHTML reset hogi
          drawer.innerHTML = newDrawer.innerHTML;
          drawer.classList.add('active');
        }
      }
    } catch (e) {
      console.warn('[ProductCards] Drawer section render failed:', e);
    }
  }

  // ─── Add to cart ─────────────────────────────────────────────────────────────

  async function addToCart(variantId, quantity) {
    const res = await fetch('/cart/add.js', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ id: variantId, quantity: quantity || 1 }),
    });
    if (!res.ok) {
      const err = await res.json().catch(() => ({}));
      throw new Error(err.description || 'Add to cart failed');
    }
    return res.json();
  }

  // ─── Click handler ───────────────────────────────────────────────────────────

  document.addEventListener('click', async function (e) {
    const button = e.target.closest('.custom-add-to-cart');
    if (!button || button.disabled) return;

    const card     = button.closest('.product-card');
    const variants = getVariants(card);
    if (!variants.length) return;

    const hasSizeSelect  = !!card.querySelector('.size-select');
    const hasColorRadios = !!card.querySelector('.color-swatch-input');

    const selectedColor = hasColorRadios ? getSelectedColor(card) : '';
    const selectedSize  = hasSizeSelect  ? getSelectedSize(card)  : '';

    if (hasSizeSelect && !selectedSize) {
      alert('Please select a size first!');
      return;
    }

    const matched = findVariant(variants, selectedColor, selectedSize);

    if (!matched) {
      alert('This combination is not available. Please select another option.');
      return;
    }

    if (!matched.available) {
      alert('Sorry, this variant is currently out of stock.');
      return;
    }

    button.disabled = true;
    const originalHTML = button.innerHTML;
    button.innerHTML = '<span>ADDING...</span>';

    try {
      await addToCart(matched.id, 1);

      // Free product logic — Black + M pe trigger hoga
      const FREE_VARIANT_ID = 8565446934713;
      if (normalize(selectedColor) === 'black' && normalize(selectedSize) === 'm') {
        await addToCart(FREE_VARIANT_ID, 1);
      }

      button.innerHTML = '<span>ADDED ✓</span>';

      // Cart count update + drawer open + section re-render
      await refreshCartCount();
      await openCartDrawer();

    } catch (err) {
      console.error('[ProductCards] Add to cart error:', err);
      button.innerHTML = '<span>ERROR — TRY AGAIN</span>';

    } finally {
      setTimeout(() => {
        button.innerHTML = originalHTML;
        button.disabled  = false;
      }, 1600);
    }
  });

  // ─── Variant change → price update ──────────────────────────────────────────

  document.addEventListener('change', function (e) {
    if (
      e.target.classList.contains('color-swatch-input') ||
      e.target.classList.contains('size-select')
    ) {
      const card = e.target.closest('.product-card');
      if (card) updatePrice(card);
    }
  });

});
</script>
 
<style>
  .custom-product-cards {
    padding: 60px 0;
  }
  .section-heading {
    text-align: center;
    margin-bottom: 40px;
  }
  .product-cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit,minmax(300px,1fr));
    gap: 24px;
  }
  .product-info-top{
    display:flex;
    align-items:flex-start;
    gap:16px;
    margin-bottom:20px;
    text-align:left;
  }
  .product-thumb{
    width:90px;
    min-width:90px;
  }
  .product-thumb img{
    width:100%;
    height:90px;
    object-fit:cover;
    border-radius:8px;
    display:block;
  }
  .product-details{
    flex:1;
  }
  .product-details h3{
    margin:0 0 8px;
    color:#fff;
    font-size:20px;
    line-height:1.2;
  }
  .product-desc{
    color:#ddd;
    font-size:13px;
    line-height:1.4;
    margin-bottom:10px;
  }
  .product-price{
    color:#fff;
    font-size:18px;
    font-weight:700;
    margin-bottom:6px;
  }
  .product-vendor{
    color:#cfcfcf;
    font-size:13px;
  }

  .variant-selection-container {
    text-align: left;
    margin-bottom: 24px;
  }
  .variant-option-group {
    margin-bottom: 16px;
  }
  .variant-label {
    display: block;
    font-size: 14px;
    color: #fff;
    margin-bottom: 8px;
    font-weight: 500;
  }
  .color-swatch-wrapper {
    display: flex;
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 4px;
    overflow: hidden;
    background: transparent;
  }
  .color-swatch-item {
    flex: 1;
    text-align: center;
    position: relative;
    border-right: 1px solid rgba(255, 255, 255, 0.4);
  }
  .color-swatch-item:last-child {
    border-right: none;
  }
  .color-swatch-input {
    position: absolute;
    opacity: 0;
    cursor: pointer;
    height: 0;
    width: 0;
  }
  .color-swatch-label {
    display: block;
    padding: 12px;
    background: transparent;
    color: #fff;
    font-size: 16px;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }
  .color-swatch-input:checked + .color-swatch-label {
    background: #ffffff;
    color: #000000;
    font-weight: bold;
  }
  
  .size-dropdown-wrapper {
    position: relative;
    width: 100%;
  }
  .variant-select {
    width: 100%;
    padding: 14px 40px 14px 16px;
    border-radius: 4px;
    border: 1px solid rgba(255, 255, 255, 0.4);
    background: transparent;
    color: #fff;
    font-size: 16px;
    appearance: none;
    -webkit-appearance: none;
    cursor: pointer;
  }
  .variant-select option {
    background: #1c1c1c;
    color: #fff;
  }
  .dropdown-chevron {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: #fff;
    pointer-events: none;
    display: flex;
    align-items: center;
  }

  .product-btn {
    width: 100%;
    padding: 16px 24px;
    border: 1px solid #ffffff;
    background: #000000;
    color: #ffffff;
    font-size: 16px;
    font-weight: bold;
    letter-spacing: 1px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    transition: all 0.3s ease;
  }
  .product-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }
  .btn-arrow {
    font-size: 20px;
    line-height: 1;
    transition: transform 0.2s;
  }
  .product-btn:hover:not(:disabled) .btn-arrow {
    transform: translateX(4px);
  }

  .product-card {
    position: relative;
    overflow: hidden;
    border-radius: 16px;
    height: 520px;
  }
  .product-card__image, .product-card__image img {
    width: 100%;
    height: 100%;
  }
  .product-card__image img {
    object-fit: cover;
    display: block;
    transition: transform .5s ease;
  }
  .product-card__plus-icon {
    position: absolute;
    transform: translate(-50%, -50%);
    width: 32px;
    height: 32px;
    background: #ffffff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    z-index: 2;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .plus-symbol {
    color: #000000;
    font-size: 20px;
    font-weight: bold;
    line-height: 1;
  }
  .product-card:hover .product-card__plus-icon {
    opacity: 0;
  }
  .product-card__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,.85);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 25px;
    opacity: 0;
    visibility: hidden;
    transition: all .35s ease;
    z-index: 3;
  }
  .product-card:hover .product-card__overlay {
    opacity: 1;
    visibility: visible;
  }
  .product-card:hover img {
    transform: scale(1.08);
  }
  .product-card__content {
    color: #fff;
    width: 100%;
  }

  /* Drawer active state — transform slide-in */
  .drawer__inner.active {
    transform: translate(0);
  }

  @media screen and (max-width: 768px) {
    .product-card__overlay {
      opacity: 1;
      visibility: visible;
      background: linear-gradient(to top, rgba(0,0,0,.95), rgba(0,0,0,.6));
    }
    .product-card__plus-icon {
      display: none;
    }
  }
</style>
 
{% schema %}
{
  "name": "Custom Product Cards",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Image"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom Title"
        },
        {
          "type": "textarea",
          "id": "custom_description",
          "label": "Custom Description"
        },
        {
          "type": "header",
          "content": "Plus Icon Position"
        },
        {
          "type": "range",
          "id": "icon_top",
          "min": 5,
          "max": 95,
          "step": 1,
          "unit": "%",
          "label": "Icon Position (Top)",
          "default": 30
        },
        {
          "type": "range",
          "id": "icon_left",
          "min": 5,
          "max": 95,
          "step": 1,
          "unit": "%",
          "label": "Icon Position (Left)",
          "default": 65
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Product Cards",
      "blocks": [
        {
          "type": "product_card"
        },
        {
          "type": "product_card"
        }
      ]
    }
  ]
}
{% endschema %}
