<section class="custom-product-cards">
  <div class="custom-product-inner">
    {% if section.settings.heading != blank %}
      <h2 class="section-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="product-cards-grid">
      {% for block in section.blocks %}
        {% assign product = block.settings.product %}
        {% if product != blank %}
          <div class="product-card" data-block-id="{{ block.id }}">
            <div class="product-card__image">
              {% if block.settings.custom_image != blank %}
                {{ block.settings.custom_image | image_url: width: 800 | image_tag: loading: 'lazy' }}
              {% elsif product.featured_image %}
                {{ product.featured_image | image_url: width: 800 | image_tag: loading: 'lazy' }}
              {% endif %}
            </div>
            <div
              class="product-card__plus-icon"
              style="top: {{ block.settings.icon_top }}%; left: {{ block.settings.icon_left }}%;--icon-top-mobile: {{ block.settings.icon_top_mobile }}%;
    --icon-left-mobile: {{ block.settings.icon_left_mobile }}%;"
            >
              {% render 'plus-icon' %}
            </div>

            <div class="ppc-popup-backdrop js-popup-backdrop">
              <div class="ppc-popup" onclick="event.stopPropagation();">
                <button type="button" class="ppc-popup__close js-popup-close">&times;</button>

                <div class="ppc-popup__body">
                  <div class="product-info-top">
                    <div class="product-thumb">
                      {% if product.featured_image -%}
                        {{- product.featured_image | image_url: width: 200 | image_tag -}}
                      {%- endif %}
                    </div>
                    <div class="product-details">
                      <h3>{{ block.settings.custom_title | default: product.title }}</h3>
                       <div class="product-price js-price-display">{{ product.price | money }}</div>
                      <div class="product-desc">
                        {{
                          block.settings.custom_description
                          | default: product.description
                          | strip_html
                          | truncate: 120
                        }}
                      </div>
                     
                    </div>
                  </div>

                  <div class="variant-selection-container">
                    {% unless product.has_only_default_variant %}
                      {% for option in product.options_with_values %}
                        <div class="variant-option-group">
                          <label class="variant-label">{{ option.name }}</label>
                          {% if option.name == 'Color' or option.name == 'color' or option.name == 'Colour' %}
                            <div class="color-swatch-wrapper">
                              {% for value in option.values %}
                                <div class="color-swatch-item">
                                  <input
                                    type="radio"
                                    id="opt-{{ block.id }}-{{ forloop.parentloop.index0 }}-{{ forloop.index0 }}"
                                    name="color-{{ block.id }}"
                                    value="{{ value | escape }}"
                                    class="color-swatch-input js-option-selector"
                                    
                                  >
                                  <label
                                    for="opt-{{ block.id }}-{{ forloop.parentloop.index0 }}-{{ forloop.index0 }}"
                                    class="color-swatch-label"
                                    style="--swatch-color: {{ value.swatch.color }};"
                                  >
                                    {{- value -}}
                                  </label>
                                </div>
                              {% endfor %}
                            </div>
                          {% else %}
                            <div class="size-dropdown-wrapper">
                              <div class="custom-select-box js-custom-select" data-selected="">
                                <div class="custom-select-trigger">
                                  <span class="custom-select-text">Choose your {{ option.name }}</span>
                                  <span class="dropdown-chevron">
                                    <svg
                                      viewBox="0 0 24 24"
                                      width="18"
                                      height="18"
                                      stroke="currentColor"
                                      stroke-width="2"
                                      fill="none"
                                    >
                                      <polyline points="6 9 12 15 18 9"></polyline>
                                    </svg>
                                  </span>
                                </div>
                                <div class="custom-select-options">
                                  {% for value in option.values %}
                                    <div class="custom-select-option" data-value="{{ value | escape }}">
                                      {{ value }}
                                    </div>
                                  {% endfor %}
                                </div>
                              </div>
                              {%- comment -%} Hidden select for JS variant matching {%- endcomment -%}
                              <select class="variant-select js-option-selector" style="display:none;">
                                <option value="" disabled selected>Choose {{ option.name }}</option>
                                {% for value in option.values %}
                                  <option value="{{ value | escape }}">{{ value }}</option>
                                {% endfor %}
                              </select>
                            </div>
                          {% endif %}
                        </div>
                      {% endfor %}
                    {% endunless %}
                  </div>

                  <button type="button" class="product-btn js-add-to-cart">
                    <span>ADD TO CART</span>
                    <span class="btn-arrow"><svg width="36" height="12" viewBox="0 0 36 12" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M0.75 4.77295L9.20657e-08 4.77295L-9.20657e-08 6.27295L0.75 6.27295L0.75 4.77295ZM34.9798 6.05328C35.2727 5.76039 35.2727 5.28551 34.9798 4.99262L30.2068 0.21965C29.9139 -0.0732432 29.4391 -0.0732433 29.1462 0.21965C28.8533 0.512544 28.8533 0.987417 29.1462 1.28031L33.3888 5.52295L29.1462 9.76559C28.8533 10.0585 28.8533 10.5334 29.1462 10.8263C29.4391 11.1191 29.9139 11.1191 30.2068 10.8263L34.9798 6.05328ZM0.75 6.27295L34.4495 6.27295L34.4495 4.77295L0.75 4.77295L0.75 6.27295Z" fill="white"/>
</svg>
</span>
                  </button>
                </div>
              </div>
            </div>

            <script class="js-raw-product-data" type="application/json">
              {
                "variants": [
                  {% for variant in product.variants %}
                    {
                      "id": {{ variant.id }},
                      "price": {{ variant.price | money | json }},
                      "available": {{ variant.available }},
                      "options": {{ variant.options | json }}
                    }{% unless forloop.last %},{% endunless %}
                  {% endfor %}
                ]
              }
            </script>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    function cleanVal(str) {
      return (str || '').toLowerCase().trim();
    }

    // TOAST HELPER
    function showToast(title, message) {
      let container = document.querySelector('.ppc-toast-container');
      if (!container) {
        container = document.createElement('div');
        container.className = 'ppc-toast-container';
        document.body.appendChild(container);
      }
      const toast = document.createElement('div');
      toast.className = 'ppc-toast';
      toast.innerHTML = `
        <div class="ppc-toast__icon">&#10005;</div>
        <div>
          <span class="ppc-toast__label">${title}</span>
          <span class="ppc-toast__msg">${message}</span>
        </div>`;
      container.appendChild(toast);
      requestAnimationFrame(() => toast.classList.add('show'));
      setTimeout(() => {
        toast.classList.remove('show');
        setTimeout(() => toast.remove(), 350);
      }, 2800);
    }

    // 1. OPEN / CLOSE POPUP
    document.querySelectorAll('.product-card').forEach((card) => {
      const plusIcon = card.querySelector('.product-card__plus-icon');
      if (plusIcon) {
        plusIcon.addEventListener('click', (e) => {
          e.stopPropagation();
          card.querySelector('.js-popup-backdrop').classList.add('active');
          document.body.style.overflow = 'hidden';
        });
      }
    });

    document.querySelectorAll('.js-popup-close, .js-popup-backdrop').forEach((closeTarget) => {
      closeTarget.addEventListener('click', function (e) {
        e.stopPropagation();
        this.closest('.js-popup-backdrop').classList.remove('active');
        document.body.style.overflow = '';
      });
    });

    // 2. CUSTOM SELECT BOX LOGIC
    document.querySelectorAll('.custom-select-box').forEach((selectBox) => {
      const trigger = selectBox.querySelector('.custom-select-trigger');
      const options = selectBox.querySelectorAll('.custom-select-option');
      const hiddenSelect = selectBox.closest('.size-dropdown-wrapper').querySelector('.variant-select');
      const textEl = selectBox.querySelector('.custom-select-text');

      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        document.querySelectorAll('.custom-select-box.open').forEach((el) => {
          if (el !== selectBox) el.classList.remove('open');
        });
        selectBox.classList.toggle('open');
      });

      options.forEach((option) => {
        option.addEventListener('click', (e) => {
          e.stopPropagation();
          const val = option.dataset.value;
          options.forEach((o) => o.classList.remove('selected'));
          option.classList.add('selected');
          textEl.textContent = option.textContent;
          selectBox.dataset.selected = val;
          selectBox.classList.remove('open');
          hiddenSelect.value = val;
          hiddenSelect.dispatchEvent(new Event('change', { bubbles: true }));
        });
      });
    });

    document.addEventListener('click', () => {
      document.querySelectorAll('.custom-select-box.open').forEach((el) => {
        el.classList.remove('open');
      });
    });

    // 3. VARIANT HELPER
    function getSelectedVariant(card) {
      const jsonEl = card.querySelector('.js-raw-product-data');
      if (!jsonEl) return null;

      const productData = JSON.parse(jsonEl.textContent);
      const radioChecked = card.querySelector('.color-swatch-input:checked');
      const dropdownSelect = card.querySelector('.variant-select');

      const val1 = radioChecked ? cleanVal(radioChecked.value) : '';
      const val2 = dropdownSelect ? cleanVal(dropdownSelect.value) : '';

      return (
        productData.variants.find((variant) => {
          const vOpts = variant.options.map((o) => cleanVal(o));
          if (val1 && val2) return vOpts.includes(val1) && vOpts.includes(val2);
          return vOpts.includes(val1) || vOpts.includes(val2);
        }) || productData.variants[0]
      );
    }

    // 4. PRICE LIVE UPDATE
    document.querySelectorAll('.product-card').forEach((card) => {
      card.addEventListener('change', function (e) {
        if (!e.target.classList.contains('js-option-selector')) return;
        const matchedVariant = getSelectedVariant(card);
        if (matchedVariant) {
          card.querySelector('.js-price-display').textContent = matchedVariant.price;
        }
      });
    });

    // 5. ADD TO CART
    document.querySelectorAll('.js-add-to-cart').forEach((btn) => {
      btn.addEventListener('click', async function (e) {
        e.stopPropagation();
        const card = this.closest('.product-card');
        const sizeDropdown = card.querySelector('.variant-select');

        if (sizeDropdown && !sizeDropdown.value) {
          showToast('SELECT SIZE', 'Please choose a size first');
          return;
        }

        const matchedVariant = getSelectedVariant(card);
        if (!matchedVariant) {
          showToast('UNAVAILABLE', 'This combination is not available');
          return;
        }
        if (!matchedVariant.available) {
          showToast('OUT OF STOCK', 'This variant is currently unavailable');
          return;
        }

        const itemsPayload = [{ id: Number(matchedVariant.id), quantity: 1 }];

        const radioChecked = card.querySelector('.color-swatch-input:checked');
        const colorValue = radioChecked ? cleanVal(radioChecked.value) : '';
        const sizeValue = sizeDropdown ? cleanVal(sizeDropdown.value) : '';

        if (colorValue === 'black' && sizeValue === 'm') {
          const FREE_GIFT_VARIANT_ID = 47592268398777;
          itemsPayload.push({ id: Number(FREE_GIFT_VARIANT_ID), quantity: 1 });
        }

        btn.disabled = true;
        btn.querySelector('span').textContent = 'ADDING...';

        try {
          const response = await fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items: itemsPayload }),
          });

          if (!response.ok) throw new Error('API Rejection');

          btn.querySelector('span').textContent = 'ADDED ✓';
          card.querySelector('.js-popup-backdrop').classList.remove('active');
          document.body.style.overflow = '';

          await triggerCartDrawerOpen();
        } catch (err) {
          console.error('[CartAPI] Error:', err);
          btn.querySelector('span').textContent = 'TRY AGAIN';
        } finally {
          setTimeout(() => {
            btn.disabled = false;
            btn.querySelector('span').textContent = 'ADD TO CART';
          }, 1500);
        }
      });
    });

    // 6. CART DRAWER OPEN
    async function triggerCartDrawerOpen() {
      try {
        const refreshRes = await fetch('/?sections=cart-drawer,cart-icon-bubble');
        const sectionData = await refreshRes.json();
        const cartDrawerEl = document.querySelector('cart-drawer');

        if (cartDrawerEl && sectionData['cart-drawer']) {
          const parsed = new DOMParser().parseFromString(sectionData['cart-drawer'], 'text/html');
          const newCartDrawer = parsed.querySelector('cart-drawer');
          if (newCartDrawer) cartDrawerEl.innerHTML = newCartDrawer.innerHTML;
          cartDrawerEl.classList.remove('is-empty');
          cartDrawerEl.classList.add('animate', 'active');
          cartDrawerEl.removeAttribute('aria-hidden');
        }

        const overlay = document.querySelector('#CartDrawer-Overlay');
        if (overlay) overlay.classList.add('active');
        document.body.classList.add('overflow-hidden');

        const bubbleEl = document.querySelector('#cart-icon-bubble');
        if (bubbleEl && sectionData['cart-icon-bubble']) {
          bubbleEl.innerHTML = new DOMParser()
            .parseFromString(sectionData['cart-icon-bubble'], 'text/html')
            .querySelector('#cart-icon-bubble').innerHTML;
        }
      } catch (e) {
        console.error('[CartDrawer] Error:', e);
        const cartDrawerEl = document.querySelector('cart-drawer');
        if (cartDrawerEl) {
          cartDrawerEl.classList.remove('is-empty');
          cartDrawerEl.classList.add('animate', 'active');
          cartDrawerEl.removeAttribute('aria-hidden');
        }
      }
    }
  });
</script>

<style>
    /* ═══════════════════════════════════════════════════════════════════════════
   TOAST NOTIFICATION
   ═══════════════════════════════════════════════════════════════════════════ */

.ppc-toast-container {
  position: fixed;
  top: 20px;
  left: 20px;
  z-index: 99999;
  display: flex;
  flex-direction: column;
  gap: 10px;
  pointer-events: none;
}

.ppc-toast {
  display: flex;
  align-items: center;
  gap: 10px;
  background: #1a1a1a;
  color: #fff;
  padding: 10px 16px 10px 12px;
  border-radius: 8px;
  font-size: 13px;
  border-left: 3px solid #e24b4a;
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
  min-width: 200px;
  max-width: 280px;
  opacity: 0;
  transform: translateX(-20px);
  transition: opacity 0.3s ease, transform 0.3s ease;
  pointer-events: auto;
}

.ppc-toast.show {
  opacity: 1;
  transform: translateX(0);
}

.ppc-toast__icon {
  width: 18px;
  height: 18px;
  background: #e24b4a;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 11px;
  font-weight: 700;
  color: #fff;
}

.ppc-toast__label {
  display: block;
  margin-bottom: 2px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.5px;
  color: #e24b4a;
}

.ppc-toast__msg {
  font-size: 13px;
  color: #fff;
}

/* ═══════════════════════════════════════════════════════════════════════════
   STRUCTURE STYLES
   ═══════════════════════════════════════════════════════════════════════════ */

.custom-product-cards {
  padding: 60px 0;
}

.section-heading {
  margin-bottom: 40px;
  font-size: 36px;
  font-family: lustria;
}

.custom-product-inner {
  padding: 0 40px;
}

.product-cards-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
  gap: 24px;
}

/* ═══════════════════════════════════════════════════════════════════════════
   COLOR SWATCH
   ═══════════════════════════════════════════════════════════════════════════ */

.color-swatch-label::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 6px;
  height: 100%;
  display: block;
  flex-shrink: 0;
  background: var(--swatch-color);
  border-right: 1px solid #000;
}

/* ═══════════════════════════════════════════════════════════════════════════
   PRODUCT CARD
   ═══════════════════════════════════════════════════════════════════════════ */

.product-card {
  position: relative;
  overflow: hidden;
  height: 444px;
}

.product-card__image,
.product-card__image img {
  width: 100%;
  height: 100%;
}

.product-card__image img {
  display: block;
  object-fit: cover;
  transition: transform 0.5s ease;
}

.product-card__plus-icon {
  position: absolute;
  z-index: 2;
  width: 22px;
  height: 22px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f8f8f8;
  border-radius: 50%;
  box-shadow: 0 4px 14px rgba(0, 0, 0, 0.25);
  cursor: pointer;
  transform: translate(-50%, -50%);
  transition: all 0.35s ease;
}

/* ═══════════════════════════════════════════════════════════════════════════
   POPUP CARD ELEMENTS
   ═══════════════════════════════════════════════════════════════════════════ */

.ppc-popup-backdrop {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: none;
  align-items: center;
  justify-content: center;
  visibility: hidden;
  background: rgba(0, 0, 0, 0);
  transition: all 0.35s ease;
}

.ppc-popup-backdrop.active {
  display: flex;
  visibility: visible;
  background: rgba(0, 0, 0, 0.65);
}

.ppc-popup {
  position: relative;
  display: none;
  width: 92%;
  max-width: 400px;
  max-height: 90vh;
  padding: 32px 28px 28px;
  overflow-y: auto;
  color: #fff;
  background: #fff;
  cursor: default;
  opacity: 0;
  transform: translateY(40px) scale(0.95);
  box-shadow:
    0 20px 60px rgba(0, 0, 0, 0.55),
    0 0 0 1px rgba(255, 255, 255, 0.08);
  transition: all 0.35s cubic-bezier(.22, .61, .36, 1);
}

.ppc-popup-backdrop.active .ppc-popup {
  display: flex;
  overflow: hidden;
  opacity: 1;
  transform: translateY(0) scale(1);
}

.ppc-popup__close {
  position: absolute;
  top: 12px;
  right: 14px;
  background: transparent;
  border: none;
  font-size: 26px;
  cursor: pointer;
}

.ppc-popup__close:hover {
  background: rgba(255, 255, 255, 0.25);
}

/* ═══════════════════════════════════════════════════════════════════════════
   PRODUCT INFO
   ═══════════════════════════════════════════════════════════════════════════ */

.product-info-top {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: flex-start;
  gap: 16px;
  margin-bottom: 10px;
  text-align: left;
}

.product-thumb {
  height: 100%;
}

.product-thumb img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
}

.product-details {
  flex: 1;
}

.product-details h3 {
  margin: 10px 0 8px;
  color: #000;
  font-size: 16px;
  line-height: 1.2;
  font-weight: 200;
}

.product-desc {
  margin-bottom: 10px;
  color: #000;
  font-size: 14px;
  line-height: 1.2;
  letter-spacing: 0;
  font-weight: 200;
}

.product-price {
  margin-top: 10px;
  margin-bottom: 6px;
  color: #000;
  font-size: 16px;
  font-weight: 400;
  font-family: lustria;
}

/* ═══════════════════════════════════════════════════════════════════════════
   VARIANT SELECTION
   ═══════════════════════════════════════════════════════════════════════════ */

.variant-selection-container {
  margin-bottom: 24px;
  text-align: left;
}

.variant-option-group {
  margin-bottom: 16px;
}

.variant-label {
  display: block;
  margin-bottom: 0;
  color: #000;
  font-size: 14px;
  font-weight: 500;
}

.color-swatch-wrapper {
  display: flex;
  overflow: hidden;
  border: 1px solid #000;
}

.color-swatch-item {
  position: relative;
  flex: 1;
  text-align: center;
  border-right: 1px solid #000;
}

.color-swatch-item:last-child {
  border-right: none;
}

.color-swatch-input {
  position: absolute;
  width: 0;
  height: 0;
  opacity: 0;
  cursor: pointer;
}

.color-swatch-label {
  position: relative;
  display: block;
  padding: 4px 12px;
  color: #000;
  font-size: 18px;
  background: transparent;
  cursor: pointer;
  transition: all 0.2s;
}
    /* ═══════════════════════════════════════════════════════════════════════════
   VARIANT STYLES
   ═══════════════════════════════════════════════════════════════════════════ */

.color-swatch-input:checked + .color-swatch-label {
  position: relative;
  background: #000;
  color: #fff;
  font-weight: bold;
}

.size-dropdown-wrapper {
  position: relative;
  width: 100%;
}

.variant-select {
  width: 100%;
  padding: 14px 40px 14px 16px;
  border: 1px solid #000;
  background: transparent;
  color: #000;
  font-size: 15px;
  appearance: none;
  -webkit-appearance: none;
  cursor: pointer;
}

.variant-select option {
  background: #fff;
  color: #000;
}

.dropdown-chevron {
  position: absolute;
  top: 50%;
  right: 16px;
  display: flex;
  align-items: center;
  color: #fff;
  pointer-events: none;
  transform: translateY(-50%);
}

/* ═══════════════════════════════════════════════════════════════════════════
   PRODUCT BUTTON
   ═══════════════════════════════════════════════════════════════════════════ */

.product-btn {
  width: 100%;
  padding: 12px 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 22px;
  border: 1px solid #fff;
  background: #000;
  color: #fff;
  font-size: 16px;
  letter-spacing: 1px;
  cursor: pointer;
  transition: all 0.3s ease;
}

.product-btn:disabled {
  opacity: 0.7;
  cursor: not-allowed;
}

.btn-arrow {
  font-size: 20px;
  line-height: 1;
  transition: transform 0.2s;
}

/* ═══════════════════════════════════════════════════════════════════════════
   CUSTOM SELECT BOX
   ═══════════════════════════════════════════════════════════════════════════ */

.custom-select-box {
  position: relative;
  width: 100%;
  user-select: none;
}

.js-custom-select.open .custom-select-trigger {
  border-bottom: 1px solid;
}

.custom-select-trigger {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 9px 16px;
  border: 1px solid #000;
  border-bottom: 0.1px;
  background: #fff;
  color: #000;
  font-size: 15px;
  cursor: pointer;
}

.custom-select-trigger::after {
  content: '';
  position: absolute;
  top: 0;
  right: 15%;
  width: 0.8px;
  height: 100%;
  display: block;
  background: #000;
}

.custom-select-options {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  z-index: 999;
  max-height: 0;
  overflow: hidden;
  border: 1px solid #000;
  border-top: 0.1px !important;
  background: #fff;
  transition: max-height 0.25s ease;
}

.custom-select-box.open .custom-select-options {
  max-height: 100px;
  overflow-y: scroll;
  scrollbar-width: none;
}

.custom-select-box.open .dropdown-chevron svg {
  transform: rotate(180deg);
}

.custom-select-option {
  padding: 3px 16px;
  color: #000;
  font-size: 15px;
  cursor: pointer;
  transition: background 0.15s;
}

.custom-select-option:last-child {
  border-bottom: none;
}

.custom-select-option:hover {
  background: #000;
  color: #fff;
}

.custom-select-option.selected {
  background: #000;
  color: #fff;
  font-weight: bold;
}

.dropdown-chevron svg {
  color: #000;
  transition: transform 0.25s ease;
}

/* ═══════════════════════════════════════════════════════════════════════════
   RESPONSIVE STYLES
   ═══════════════════════════════════════════════════════════════════════════ */

@media screen and (max-width: 768px) {

  .product-card__plus-icon {
    width: 15px;
    height: 15px;
    top: var(--icon-top-mobile) !important;
    left: var(--icon-left-mobile) !important;
  }

  .product-card__plus-icon svg {
    width: 7px;
    height: 8px;
  }

  .ppc-popup {
    max-width: 96%;
    padding: 24px 20px 20px;
  }

  .custom-product-inner {
    padding: 0 1.5rem;
  }

  .product-cards-grid {
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .product-card {
    height: auto;
    aspect-ratio: 2 / 2;
  }

  .section-heading {
    margin-top: 10px;
    margin-bottom: 15px;
    text-align: center;
    font-size: 24px;
    font-family: lustria;
  }

  .custom-product-cards {
    padding: 35px 0;
  }

  .ppc-toast-container {
    top: 12px;
    left: 12px;
  }

  .ppc-toast {
    min-width: 180px;
    max-width: 240px;
  }
}
</style>

{% schema %}
{
  "name": "Custom Product Cards",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Image"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom Title"
        },
        {
          "type": "textarea",
          "id": "custom_description",
          "label": "Custom Description"
        },
        {
          "type": "header",
          "content": "Plus Icon Position"
        },
        {
          "type": "range",
          "id": "icon_top",
          "min": 5,
          "max": 95,
          "step": 1,
          "unit": "%",
          "label": "Icon Position (Top)",
          "default": 30
        },
        {
          "type": "range",
          "id": "icon_left",
          "min": 5,
          "max": 95,
          "step": 1,
          "unit": "%",
          "label": "Icon Position (Left)",
          "default": 65
        },
        {
          "type": "header",
          "content": "Plus Icon Position — Mobile"
        },
        {
          "type": "range",
          "id": "icon_top_mobile",
          "min": 5,
          "max": 95,
          "step": 1,
          "unit": "%",
          "label": "Icon Position Mobile (Top)",
          "default": 30
        },
        {
          "type": "range",
          "id": "icon_left_mobile",
          "min": 5,
          "max": 95,
          "step": 1,
          "unit": "%",
          "label": "Icon Position Mobile (Left)",
          "default": 65
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Product Cards",
      "blocks": [{ "type": "product_card" }, { "type": "product_card" }]
    }
  ]
}
{% endschema %}