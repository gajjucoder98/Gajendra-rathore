<div class="tisso-gift-bar" id="gift-bar-{{ section.id }}">
  <div class="bar-container">
    
    <!-- Mobile-Only Hamburger Toggle -->
    <button type="button" class="bar-toggle" aria-label="Toggle Navigation">
      <div class="hamburger-icon">
        <span></span>
        <span></span>
        <span></span>
      </div>
    </button>

    <!-- Logo Section with Clean Right-to-Left Shift Animation -->
    <div class="bar-brand">
      {% if section.settings.brand_image != blank %}
        <img src="{{ section.settings.brand_image | img_url: 'master' }}" alt="{{ shop.name }}" class="brand-img-element">
      {% else %}
        <span style="font-size: 16px; font-weight: bold; letter-spacing: 1px;">UPLOAD LOGO</span>
      {% endif %}
    </div>

    <!-- Content Panel -->
    <div class="bar-overlay-panel">
      <div class="panel-inner">
        <p class="bar-message">{{ section.settings.message_text }}</p>
        <a href="{{ section.settings.btn_link }}" class="bar-btn">
          {{ section.settings.btn_text }}
          <svg class="arrow-icon" viewBox="0 0 24 24" width="20" height="20">
            <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const wrapper = document.getElementById('gift-bar-{{ section.id }}');
  const toggleBtn = wrapper.querySelector('.bar-toggle');
  
  if (toggleBtn) {
    toggleBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      wrapper.classList.toggle('is-active');
    });
  }

  document.addEventListener('click', function(e) {
    if (!wrapper.contains(e.target)) {
      wrapper.classList.remove('is-active');
    }
  });
});
</script>

<style>
  /* ========================================== */
  /* DESKTOP CORE STYLES                        */
  /* ========================================== */
  .tisso-gift-bar {
    background-color: #f6f6f6;
    border-bottom: 1px solid #e2e2e2;
    position: relative;
    font-family: "Futura", "Helvetica Neue", Helvetica, Arial, sans-serif;
    z-index: 9999;
    width: 100%;
  }
  .bar-container {
    max-width: 100%;
    height: 75px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .bar-toggle {
    display: none;
  }
  .bar-brand {
    display: flex;
    align-items: center;
  }
  .brand-img-element {
    max-height: 28px;
    width: auto;
    display: block;
    object-fit: contain;
  }
  
  .bar-overlay-panel {
    display: flex;
    align-items: center;
    flex: 1;
    justify-content: space-between;
  }
  .panel-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    margin-left: 60px;
  }
  .bar-message {
    font-size: 14px;
    color: #1c1c1c;
    margin: 0;
    font-weight: 400;
    letter-spacing: 0.2px;
  }
  .bar-btn {
    background-color: #ffff00;
    color: #000000;
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 1px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 12px 35px;
    text-transform: uppercase;
    transition: opacity 0.15s ease;
  }
  .bar-btn:hover { opacity: 0.9; }
  .arrow-icon { display: inline-block; transition: transform 0.15s ease; }
  .bar-btn:hover .arrow-icon { transform: translateX(3px); }

  /* ========================================== */
  /* MOBILE BREAKPOINT TARGET                   */
  /* ========================================== */
  @media screen and (max-width: 989px) {
    .bar-container {
      height: 65px;
      padding: 0 20px;
      position: relative;
    }
    .bar-toggle {
      display: flex;
      background: none;
      border: none;
      cursor: pointer;
      padding: 10px 10px 10px 0;
      z-index: 10001;
    }
    .hamburger-icon {
      width: 22px;
      height: 14px;
      position: relative;
    }
    .hamburger-icon span {
      display: block;
      position: absolute;
      height: 2px;
      width: 100%;
      background: #000000;
      transition: all 0.2s ease-in-out;
    }
    .hamburger-icon span:nth-child(1) { top: 0; }
    .hamburger-icon span:nth-child(2) { top: 6px; }
    .hamburger-icon span:nth-child(3) { top: 12px; }

    .is-active .hamburger-icon span:nth-child(1) { top: 6px; transform: rotate(45deg); }
    .is-active .hamburger-icon span:nth-child(2) { opacity: 0; }
    .is-active .hamburger-icon span:nth-child(3) { top: 6px; transform: rotate(-45deg); }

    /* Centered Mobile Logo Container */
    .bar-brand {
      position: absolute;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      pointer-events: none;
      z-index: 10000;
    }

    /* Target Image for Clean Animation Performance */
    .brand-img-element {
      max-height: 28px;
      /* Default state jab panel band ho (animation to center) */
      animation: shiftToCenter 0.3s cubic-bezier(0.25, 1, 0.5, 1) forwards;
      will-change: transform;
    }

    /* Active State (Trigger animation to Left) */
    .is-active .brand-img-element {
      animation: shiftToLeft 0.3s cubic-bezier(0.25, 1, 0.5, 1) forwards;
    }

    /* Right to Left Slide (End state completely clean/simple) */
    @keyframes shiftToLeft {
      0% {
        transform: translateX(0);
      }
      30% {
        transform: translateX(3px); /* Halki si positioning illusion transition ke liye */
      }
      100% {
        transform: translateX(-4px); /* Apni simple final left pos par aakar ruk gaya */
      }
    }

    /* Smooth Slide Back to Original Center Position */
    @keyframes shiftToCenter {
      0% {
        transform: translateX(-4px);
      }
      100% {
        transform: translateX(0); /* Absolute center default simple state */
      }
    }

    /* Overlay Panel Dropdown */
    .bar-overlay-panel {
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      background-color: #f6f6f6;
      border-bottom: 1px solid #e2e2e2;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
      display: block;
      transform: translateY(-15px);
      opacity: 0;
      visibility: hidden;
      transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.25s ease;
    }
    .is-active .bar-overlay-panel {
      transform: translateY(0);
      opacity: 1;
      visibility: visible;
    }
    .panel-inner {
      flex-direction: column;
      max-width: 100%;
      margin-left: 0;
      padding: 24px 20px 32px 20px;
      text-align: center;
      gap: 20px;
    }
    .bar-message {
      font-size: 16px;
      text-align: center;
    }
    .bar-btn {
      width: 100%;
      box-sizing: border-box;
      padding: 14px 45px;
    }
  }
</style>

{% schema %}
{
  "name": "Tisso Gift Header Bar",
  "settings": [
    { "type": "image_picker", "id": "brand_image", "label": "Select Logo Image" },
    { "type": "text", "id": "message_text", "label": "Message Text", "default": "Find the ideal gift for your loved ones." },
    { "type": "text", "id": "btn_text", "label": "Button Label", "default": "CHOOSE GIFT" },
    { "type": "url", "id": "btn_link", "label": "Button Link" }
  ],
  "presets": [
    { "name": "Tisso Gift Header Bar" }
  ]
}
{% endschema %}