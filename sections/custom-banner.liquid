<div class="tisso-gift-bar" id="gift-bar-{{ section.id }}">
  <div class="bar-container">
    <button type="button" class="bar-toggle" aria-label="Toggle Navigation">
      <div class="hamburger-icon">
        <span></span>
        <span></span>
        <span></span>
      </div>
    </button>

    <div class="bar-brand">
      {% if section.settings.brand_image != blank %}
        <img
          src="{{ section.settings.brand_image | img_url: 'master' }}"
          alt="{{ shop.name }}"
          class="brand-img-element base-layer"
        >
        <img
          src="{{ section.settings.brand_image | img_url: 'master' }}"
          alt="{{ shop.name }}"
          class="brand-img-element overlay-layer"
        >
      {% else %}
        <span style="font-size: 16px; font-weight: bold; letter-spacing: 1px;">UPLOAD LOGO</span>
      {% endif %}
    </div>
    <p class="bar-message bar-message-phn">{{ section.settings.message_text }}</p>
    <a href="{{ section.settings.btn_link }}" class="bar-btn bar-btn-phn">
      {{ section.settings.btn_text }}
      <svg width="27" height="12" viewBox="0 0 27 12" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0.75 4.77298L7.83954e-08 4.77298L-7.83954e-08 6.27298L0.75 6.27298L0.75 5.52298L0.75 4.77298ZM26.7876 6.05331C27.0805 5.76042 27.0805 5.28554 26.7876 4.99265L22.0146 0.21968C21.7217 -0.073213 21.2468 -0.073213 20.9539 0.21968C20.6611 0.512574 20.6611 0.987447 20.9539 1.28034L25.1966 5.52298L20.9539 9.76562C20.6611 10.0585 20.6611 10.5334 20.9539 10.8263C21.2468 11.1192 21.7217 11.1192 22.0146 10.8263L26.7876 6.05331ZM0.75 5.52298L0.75 6.27298L26.2572 6.27298L26.2572 5.52298L26.2572 4.77298L0.75 4.77298L0.75 5.52298Z" fill="black"/>
      </svg>
    </a>
    <div class="bar-overlay-panel">
      <div class="panel-inner">
        <p class="bar-message">{{ section.settings.message_text }}</p>
        <a href="{{ section.settings.btn_link }}" class="bar-btn">
          {{ section.settings.btn_text }}
          <svg class="arrow-icon" viewBox="0 0 24 24" width="20" height="20">
            <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</div>

<section
  class="gift-guide-banner"
  style="
    --desktop-bg:url('{{ section.settings.desktop_bg | image_url: width: 2500 }}');
    --mobile-bg:url('{{ section.settings.mobile_bg | image_url: width: 1000 }}');
  "
>
  <div class="gift-guide-banner__content ">
    <div class="gift-banner-content-wraper">
      {% if section.settings.heading != blank %}
        <h2 class="gift-guide-banner__heading">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="gift-guide-banner__description">
          {{ section.settings.description }}
        </div>
      {% endif %}
    </div>
    {% if section.settings.button_text != blank %}
      <a
        href="{{ section.settings.button_link }}"
        class="gift-guide-banner__button"
      >
        {{ section.settings.button_text }}
        <span>→</span>
      </a>
    {% endif %}
  </div>

  <div class="gift-guide-banner__bottom-strip">
    {{ section.settings.bottom_text }}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const wrapper = document.getElementById('gift-bar-{{ section.id }}');
    const toggleBtn = wrapper.querySelector('.bar-toggle');

    if (toggleBtn) {
      toggleBtn.addEventListener('click', function (e) {
        e.stopPropagation();

        if (wrapper.classList.contains('is-active')) {
          // Menu close ho rha h: .is-closing lagao reverse animation ke liye
          wrapper.classList.remove('is-active');
          wrapper.classList.add('is-closing');

          // Animation khatam hote hi closing class hta do
          setTimeout(() => {
            wrapper.classList.remove('is-closing');
          }, 650);
        } else {
          // Menu open ho rha h
          wrapper.classList.remove('is-closing');
          wrapper.classList.add('is-active');
        }
      });
    }

    document.addEventListener('click', function (e) {
      if (!wrapper.contains(e.target) && wrapper.classList.contains('is-active')) {
        wrapper.classList.remove('is-active');
        wrapper.classList.add('is-closing');
        setTimeout(() => {
          wrapper.classList.remove('is-closing');
        }, 650);
      }
    });
  });
</script>

<style>
    

  /* =====================================================

  1. DESKTOP - GIFT BAR
     ===================================================== */

  .tisso-gift-bar {
    background-color: #f6f6f6;
    border-bottom: 1px solid #e2e2e2;
    position: relative;
    width: 100%;
    z-index: 9999;
    font-family: "Futura", "Helvetica Neue", Helvetica, Arial, sans-serif;
  }

  .bar-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 100%;
    height: 75px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .bar-toggle {
    display: none;
  }

  .bar-brand {
    display: flex;
    align-items: center;
    position: relative;
  }

  .brand-img-element {
    display: block;
    width: auto;
    max-height: 28px;
    object-fit: contain;
  }

  .overlay-layer {
    display: none !important;
  }

  /* =====================================================
  DESKTOP CONTENT AREA
  ===================================================== */

  .bar-overlay-panel {
    display: none;
    flex: 1;
    align-items: center;
    justify-content: space-between;
  }

  .panel-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    margin-left: 60px;
  }

  .bar-message {
    margin: 0;
    color: #1c1c1c;
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.2px;
  }

  /* =====================================================
  BUTTON STYLES
  ===================================================== */

  .bar-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 40px;
    background: #fff544;
    color: #000;
    text-decoration: none;
    overflow: hidden;
    z-index: 1;
    transition: color 0.35s ease;
  }

  .bar-btn::before {
    content: "";
    position: absolute;
    inset: 0;
    width: 0;
    background: #000;
    transition: width 0.35s ease;
    z-index: -1;
  }

  .bar-btn:hover::before {
  width: 100%;
  }
.bar-btn:hover svg{
    stroke:#fff;
}
.bar-btn:hover svg path{
    fill:#fff;
}
  .bar-btn:hover {
  color: #fff;
  }

  .arrow-icon {
  display: inline-block;
  transition: transform 0.15s ease;
  }

  .bar-btn:hover .arrow-icon {
  transform: translateX(3px);
  }

  /* =====================================================
  MOBILE STYLES (≤ 989px)
  ===================================================== */

  @media screen and (max-width: 989px) {

  .bar-container {
  position: relative;
  height: 65px;
  padding: 0 20px;
  }

  .bar-message-phn,
  .bar-btn-phn {
  display: none;
  }

  /* ==========================================
  HAMBURGER MENU
  ========================================== */

  .bar-toggle {
  display: flex;
  padding: 10px 10px 10px 0;
  background: none;
  border: none;
  cursor: pointer;
  z-index: 10001;
  }

  .hamburger-icon {
  position: relative;
  width: 22px;
  height: 14px;
  }

  .hamburger-icon span {
  position: absolute;
  display: block;
  width: 100%;
  height: 2px;
  background: #000;
  transition: all 0.25s ease-in-out;
  }

  .hamburger-icon span:nth-child(1) { top: 0; }
  .hamburger-icon span:nth-child(2) { top: 6px; }
  .hamburger-icon span:nth-child(3) { top: 12px; }

  .is-active .hamburger-icon span:nth-child(1) {
  top: 6px;
  transform: rotate(45deg);
  }

  .is-active .hamburger-icon span:nth-child(2) {
  opacity: 0;
  }

  .is-active .hamburger-icon span:nth-child(3) {
  top: 6px;
  transform: rotate(-45deg);
  }

  /* ==========================================
  LOGO POSITIONING
  ========================================== */

  .bar-brand {
    position: absolute;
    top: 50%;
    left: 50%;
    width: auto;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 10000;
    transform: translate(-50%, -50%);
  }

  /* ==========================================
  LOGO ANIMATION
  ========================================== */

  .base-layer {
    position: relative;
    opacity: 1;
    transform: translateX(0);
    transition: transform 0.65s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .overlay-layer {
    display: block !important;
    position: absolute;
    opacity: 0;
    pointer-events: none;
    transform: translateX(6px);
    transition: transform 0.65s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .is-active .base-layer {
  transform: translateX(-4px);
  }

  .is-active .overlay-layer { 
    transform: translateX(-4px);
    animation: clearOverlayOnActive 0.65s cubic-bezier(0.25, 1, 0.5, 1) forwards;
  }

  @keyframes clearOverlayOnActive {
    0% { opacity: 0.4; }
    75% { opacity: 0.15; }
    100% { opacity: 0; }
  }

  .is-closing .base-layer {
    transform: translateX(0);
  }

  .is-closing .overlay-layer {
    transform: translateX(6px);
    animation: clearOverlayOnClosing 0.65s cubic-bezier(0.25, 1, 0.5, 1) forwards;
  }

  @keyframes clearOverlayOnClosing {
    0% {
    opacity: 0;
    transform: translateX(-4px);
    }

    ```
    30% {
      opacity: 0.3;
    }

    100% {
      opacity: 0;
      transform: translateX(6px);
    }
  }

  /* ==========================================
  DROPDOWN PANEL
  ========================================== */

  .bar-overlay-panel {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    display: block;
    background: #f6f6f6;
    border-bottom: 1px solid #e2e2e2;
    box-shadow: 0 10px 25px rgba(0,0,0,.08);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-15px);
    transition:
      transform .4s cubic-bezier(0.16,1,0.3,1),
      opacity .3s ease;
  }

  .is-active .bar-overlay-panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .panel-inner {
    flex-direction: column;
    gap: 20px;
    max-width: 100%;
    margin-left: 0;
    padding: 24px 20px 32px;
    text-align: center;
  }

  .bar-message {
    font-size: 16px;
    text-align: center;
  }

  .bar-btn {
    width: 100%;
    padding: 14px 45px;
    box-sizing: border-box;
  }
  }

  /* =====================================================
  GIFT GUIDE BANNER
  ===================================================== */

  .gift-guide-banner {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 820px;
    background-image: var(--desktop-bg);
    background-repeat: no-repeat;
    background-position: left;
    background-size: cover;
  }

  .gift-guide-banner__content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    max-width: 600px;
    padding: 0 32px 60px;
  }

  .gift-guide-banner__heading {
    margin: 0 0 15px;
    font-size: 70px;
    line-height: 1;
    font-weight: 500;
  }

  .gift-guide-banner__description {
    max-width: 500px;
    margin-bottom: 32px;
    font-size: 20px;
    line-height: 1.2;
  }

  .gift-guide-banner__button {
    display: flex;
    align-items: center;
    gap: 12px;
    width: max-content;
    padding: 11px 49px;
    background: #000;
    color: #fff;
    text-decoration: none;
    font-size: 16px;
    font-weight: 400;
  }

  .gift-guide-banner__bottom-strip {
    padding: 10px;
    background: #f5f5f5;
    text-align: center;
    font-size: 16px;
    font-weight: 400;
    letter-spacing: .08em;
    text-transform: uppercase;
  }

  /* =====================================================
  GIFT GUIDE BANNER - MOBILE (≤ 749px)
  ===================================================== */

  @media screen and (max-width: 749px) {

    .gift-guide-banner {
      min-height: 620px;
      background-image: var(--mobile-bg);
      background-position: center bottom;
    }

    .gift-guide-banner__content {
      max-width: 100%;
      padding: 40px 24px;
      align-items: center;
      justify-content: space-between;
      text-align: center;
    }

    .gift-guide-banner__heading {
      margin: 25px 0 15px;
      font-size: 30px;
      line-height: 1.1;
      font-weight: 600;
    }

    .gift-guide-banner__description {
      max-width: 100%;
      margin-bottom: 25px;
      padding: 0 10px;
      font-size: 16px;
      line-height: 1.4;
    }

    .gift-guide-banner__button {
      width: 80%;
      max-width: 193px;
      justify-content: center;
      padding: 9px 30px;
      font-size: 15px;
      letter-spacing: .05em;
    }

    .gift-guide-banner__bottom-strip {
        padding: 12px 10px;
        font-size: 13px;
        letter-spacing: .06em;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
 }
</style>

{% schema %}
{
  "name": "Tisso Gift Section",
  "settings": [
    { "type": "image_picker", "id": "brand_image", "label": "Select Logo Image" },
    {
      "type": "text",
      "id": "message_text",
      "label": "Message Text",
      "default": "Find the ideal gift for your loved ones."
    },
    { "type": "text", "id": "btn_text", "label": "Button Label", "default": "CHOOSE GIFT" },
    { "type": "url", "id": "btn_link", "label": "Button Link" },
    {
      "type": "image_picker",
      "id": "desktop_bg",
      "label": "Desktop Background Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_bg",
      "label": "Mobile Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "bottom_text",
      "label": "Bottom Strip Text",
      "default": "SUSTAINABLE, ETHICALLY MADE ACTIVEWEAR"
    }
  ],
  "presets": [
    {
      "name": "Tisso Gift Section"
    }
  ]
}
{% endschema %}
