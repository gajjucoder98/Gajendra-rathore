<div class="tisso-gift-bar" id="gift-bar-{{ section.id }}">
  <div class="bar-container">
    <div class="bar-brand">{{ section.settings.brand_text }}</div>
    <div class="bar-msg">{{ section.settings.message_text }}</div>
    <div class="bar-action">
      <a href="{{ section.settings.btn_link }}" class="gift-yellow-btn">
        {{ section.settings.btn_text }} <span>→</span>
      </a>
    </div>
  </div>
</div>

<style>
  .tisso-gift-bar {
    background: #f3f3f3;
    padding: 12px 20px;
    border-bottom: 1px solid #e5e5e5;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }
  .bar-container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 15px;
  }
  .bar-brand {
    font-weight: 700;
    font-size: 18px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #000;
    flex: 1;
  }
  .bar-msg {
    font-size: 13px;
    color: #333;
    text-align: center;
    flex: 2;
  }
  .bar-action {
    text-align: right;
    flex: 1;
  }
  .gift-yellow-btn {
    background: #fff700;
    color: #000;
    padding: 10px 22px;
    font-size: 12px;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 0.5px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-transform: uppercase;
    transition: opacity 0.2s;
  }
  .gift-yellow-btn:hover { opacity: 0.9; }

  /* Mobile Clean Responsive Layout */
  @media screen and (max-width: 768px) {
    .bar-container {
      flex-direction: column;
      gap: 10px;
      text-align: center;
    }
    .bar-brand, .bar-msg, .bar-action {
      flex: none;
      width: 100%;
      text-align: center;
    }
    .gift-yellow-btn {
      width: 100%;
      justify-content: center;
      padding: 12px;
    }
  }
</style>

{% schema %}
{
  "name": "Tisso Gift Header Bar",
  "settings": [
    { "type": "text", "id": "brand_text", "label": "Brand Name", "default": "TISSO VISON" },
    { "type": "text", "id": "message_text", "label": "Message", "default": "Find the ideal gift for your loved ones." },
    { "type": "text", "id": "btn_text", "label": "Button Label", "default": "CHOOSE GIFT" },
    { "type": "url", "id": "btn_link", "label": "Button Link" }
  ],
  "presets": [{ "name": "Tisso Gift Header Bar" }]
}
{% endschema %}