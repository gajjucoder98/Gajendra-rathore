<section
  class="gift-guide-banner"
  style="
    --desktop-bg:url('{{ section.settings.desktop_bg | image_url: width: 2500 }}');
    --mobile-bg:url('{{ section.settings.mobile_bg | image_url: width: 1000 }}');
  "
>
  <div class="gift-guide-banner__topbar">

    <div class="gift-guide-banner__logo">
      {{ section.settings.top_logo_text }}
    </div>

    <div class="gift-guide-banner__center-text">
      {{ section.settings.top_center_text }}
    </div>

    {% if section.settings.top_button_text != blank %}
      <a
        href="{{ section.settings.top_button_link }}"
        class="gift-guide-banner__top-btn"
      >
        {{ section.settings.top_button_text }}
        <span>→</span>
      </a>
    {% endif %}

  </div>

  <div class="gift-guide-banner__content page-width">

    {% if section.settings.heading != blank %}
      <h2 class="gift-guide-banner__heading">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% if section.settings.description != blank %}
      <div class="gift-guide-banner__description">
        {{ section.settings.description }}
      </div>
    {% endif %}

    {% if section.settings.button_text != blank %}
      <a
        href="{{ section.settings.button_link }}"
        class="gift-guide-banner__button"
      >
        {{ section.settings.button_text }}
        <span>→</span>
      </a>
    {% endif %}

  </div>

  <div class="gift-guide-banner__bottom-strip">
    {{ section.settings.bottom_text }}
  </div>
</section>
<style>

.gift-guide-banner{
  position:relative;
  min-height:850px;
  background-image:var(--desktop-bg);
  background-size:cover;
  background-position:center;
  background-repeat:no-repeat;
  display:flex;
  flex-direction:column;
}

.gift-guide-banner__topbar{
  height:64px;
  background:#f3f3f3;
  display:grid;
  grid-template-columns:1fr auto 1fr;
  align-items:center;
  padding:0 32px;
  border-bottom:1px solid rgba(0,0,0,.08);
}

.gift-guide-banner__logo{
  font-size:18px;
  font-weight:700;
  letter-spacing:.05em;
}

.gift-guide-banner__center-text{
  text-align:center;
  font-size:16px;
  font-weight:400;
}

.gift-guide-banner__top-btn{
  justify-self:end;
  background:#f3e61f;
  color:#000;
  text-decoration:none;
  padding:9px 28px;
  font-weight:400;
  display:flex;
  align-items:center;
  gap:10px;
}

.gift-guide-banner__content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    max-width: 600px;
    align-items: flex-start;
    padding: 0px 32px;
    padding-bottom: 60px;
}

.gift-guide-banner__heading{
  font-size:70px;
  line-height:1;
  font-weight:500;
  margin:0 0 25px;
}

.gift-guide-banner__description{
  max-width:500px;
  font-size:20px;
  line-height:1.2;
  margin-bottom:32px;
}

.gift-guide-banner__button{
  width:max-content;
  background:#000;
  color:#fff;
  text-decoration:none;
  padding:16px 34px;
  display:flex;
  align-items:center;
  gap:12px;
  font-weight:600;
}

.gift-guide-banner__bottom-strip{
  background:#efefef;
  text-align:center;
  padding:10px;
  font-size:12px;
  text-transform:uppercase;
  letter-spacing:.08em;
}

@media screen and (max-width: 749px){

  .gift-guide-banner{
    min-height:700px;
    background-image:var(--mobile-bg);
  }

  .gift-guide-banner__topbar{
    grid-template-columns:1fr;
    gap:10px;
    height:auto;
    padding:15px;
    text-align:center;
  }

  .gift-guide-banner__top-btn{
    justify-self:center;
  }

  .gift-guide-banner__logo{
    font-size:22px;
  }

  .gift-guide-banner__heading{
    font-size:46px;
  }

  .gift-guide-banner__description{
    font-size:16px;
  }

  .gift-guide-banner__content{
    padding:40px 20px;
  }
}

</style>
{% schema %}
{
  "name": "Gift Guide Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_bg",
      "label": "Desktop Background Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_bg",
      "label": "Mobile Background Image"
    },
    {
      "type": "text",
      "id": "top_logo_text",
      "label": "Top Left Text",
      "default": "TISSO VISION"
    },
    {
      "type": "text",
      "id": "top_center_text",
      "label": "Top Center Text",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "top_button_text",
      "label": "Top Right Button Text",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "top_button_link",
      "label": "Top Right Button Link"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gift to delight your loved ones this holiday season.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "bottom_text",
      "label": "Bottom Strip Text",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    }
  ],
  "presets": [
    {
      "name": "Gift Guide Banner"
    }
  ]
}
{% endschema %}