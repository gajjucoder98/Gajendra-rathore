<section
  class="gift-guide-banner"
  style="
    --desktop-bg:url('{{ section.settings.desktop_bg | image_url: width: 2500 }}');
    --mobile-bg:url('{{ section.settings.mobile_bg | image_url: width: 1000 }}');
  "
>
  <div class="gift-guide-banner__topbar">

    <button type="button" class="gift-guide-banner__menu-toggle" aria-label="Toggle Menu" onclick="this.closest('.gift-guide-banner__topbar').classList.toggle('is-open')">
      <svg class="icon icon-hamburger" viewBox="0 0 18 16" width="18" height="16">
        <path d="M1 .5h16a.5.5 0 0 1 0 1H1a.5.5 0 0 1 0-1zm0 7h16a.5.5 0 0 1 0 1H1a.5.5 0 0 1 0-1zm0 7h16a.5.5 0 0 1 0 1H1a.5.5 0 0 1 0-1z" fill="currentColor"/>
      </svg>
      <svg class="icon icon-close" viewBox="0 0 18 18" width="18" height="18">
        <path d="M1 1l16 16M17 1L1 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

    <div class="gift-guide-banner__logo">
      {{ section.settings.top_logo_text }}
    </div>

    <div class="gift-guide-banner__center-text">
      {{ section.settings.top_center_text }}
    </div>

    {% if section.settings.top_button_text != blank %}
      <a
        href="{{ section.settings.top_button_link }}"
        class="gift-guide-banner__top-btn"
      >
        {{ section.settings.top_button_text }}
        <span>→</span>
      </a>
    {% endif %}

  </div>

  <div class="gift-guide-banner__content ">

    {% if section.settings.heading != blank %}
      <h2 class="gift-guide-banner__heading">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% if section.settings.description != blank %}
      <div class="gift-guide-banner__description">
        {{ section.settings.description }}
      </div>
    {% endif %}

    {% if section.settings.button_text != blank %}
      <a
        href="{{ section.settings.button_link }}"
        class="gift-guide-banner__button"
      >
        {{ section.settings.button_text }}
        <span>→</span>
      </a>
    {% endif %}

  </div>

  <div class="gift-guide-banner__bottom-strip">
    {{ section.settings.bottom_text }}
  </div>
</section>

<style>
/* --- DESKTOP STYLES (Bilkul Unchanged) --- */
.gift-guide-banner{
  position:relative;
  min-height:820px;
  background-image:var(--desktop-bg);
  background-size:cover;
  background-position:left;
  background-repeat:no-repeat;
  display:flex;
  flex-direction:column;
}

.gift-guide-banner__topbar{
  height:64px;
  background:#F5F5F5;
  display:grid;
  grid-template-columns:1fr auto 1fr;
  align-items:center;
  padding:0 32px;
  border-bottom:1px solid rgba(0,0,0,.08);
  transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1); /* Smooth Layout Shift Transition */
}

/* Logo Smooth Dropdown Animation Setup */
.gift-guide-banner__logo{
  font-size:18px;
  font-weight:700;
  letter-spacing:.05em;
  transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), font-size 0.4s ease;
}

.gift-guide-banner__center-text{
  text-align:center;
  font-size:16px;
  font-weight:400;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}

.gift-guide-banner__top-btn{
  justify-self:end;
  background:#f3e61f;
  color:#000;
  text-decoration:none;
  padding:9px 28px;
  font-weight:400;
  display:flex;
  align-items:center;
  gap:10px;
  transition: all 0.3s ease;
}

/* Default Desktop me Hamburger Hided rahega */
.gift-guide-banner__menu-toggle {
  display: none;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  color: #000;
}

.gift-guide-banner__content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    max-width: 600px;
    align-items: flex-start;
    padding: 0px 32px;
    padding-bottom: 60px;
}

.gift-guide-banner__heading{
  font-size:70px;
  line-height:1;
  font-weight:500;
  margin:0 0 15px;
}

.gift-guide-banner__description{
  max-width:500px;
  font-size:20px;
  line-height:1.2;
  margin-bottom:32px;
}

.gift-guide-banner__button {
    width: max-content;
    background: #000;
    color: #fff;
    text-decoration: none;
    padding: 11px 49px;
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 400;
    font-size: 16px;
}

.gift-guide-banner__bottom-strip{
  background:#F5F5F5;
  text-align:center;
  padding:10px;
  font-size:16px;
  font-weight:400;
  text-transform:uppercase;
  letter-spacing:.08em;
}

/* --- MOBILE STYLES (Video Se Exact Matched) --- */
@media screen and (max-width: 749px){

  .gift-guide-banner{
    min-height:700px;
    background-image:var(--mobile-bg);
  }

  /* Video style Layout Shift & Animation Configuration */
  .gift-guide-banner__topbar{
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: #ffffff; /* Video me background topbar ka white hai */
    height: auto;
    padding: 20px 15px;
    gap: 15px;
    position: relative;
    overflow: hidden;
  }

  /* Hamburger and Close Icons control */
  .gift-guide-banner__menu-toggle {
    display: block;
    position: absolute;
    left: 20px;
    top: 24px;
    z-index: 10;
  }
  
  .gift-guide-banner__menu-toggle .icon-close {
    display: none;
  }

  /* Jab Menu Open (is-open Class active) ho tab Toggle Icon switch hoga */
  .gift-guide-banner__topbar.is-open .gift-guide-banner__menu-toggle .icon-hamburger {
    display: none;
  }
  .gift-guide-banner__topbar.is-open .gift-guide-banner__menu-toggle .icon-close {
    display: block;
  }

  /* Logo Animation: Video ke according position scaling dropdown toggle par */
  .gift-guide-banner__logo{
    font-size: 24px;
    order: 1;
    margin-top: 5px;
    transform: translateY(0);
  }

  /* Dropdown open hone pr smooth reposition animation */
  .gift-guide-banner__topbar.is-open .gift-guide-banner__logo {
    transform: translateY(2px) scale(1.02);
  }

  .gift-guide-banner__center-text{
    order: 2;
    font-size: 14px;
    margin: 5px 0 2px 0;
    width: 100%;
    opacity: 1;
    visibility: visible;
    transition: opacity 0.3s ease;
  }

  .gift-guide-banner__top-btn{
    order: 3;
    justify-self: center;
    width: 85%; /* Video me full width block type horizontal strip hai button */
    justify-content: center;
    padding: 12px 20px;
    font-size: 15px;
    letter-spacing: 0.05em;
  }

  /* Dropdown Close/Hide State Flow handling */
  .gift-guide-banner__topbar:not(.is-open) .gift-guide-banner__center-text,
  .gift-guide-banner__topbar:not(.is-open) .gift-guide-banner__top-btn {
    display: none; /* Video me dropdown close hone par items structural layer se out ho rhe hain */
  }

  /* Banner Content Responsiveness */
  .gift-guide-banner__heading{
    font-size:46px;
  }

  .gift-guide-banner__description{
    font-size:16px;
  }

  .gift-guide-banner__content{
    padding:40px 20px;
  }
}
</style>

{% schema %}
{
  "name": "Gift Guide Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_bg",
      "label": "Desktop Background Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_bg",
      "label": "Mobile Background Image"
    },
    {
      "type": "text",
      "id": "top_logo_text",
      "label": "Top Left Text",
      "default": "TISSO VISON"
    },
    {
      "type": "text",
      "id": "top_center_text",
      "label": "Top Center Text",
      "default": "Get started with your \"Mi Solo\" kit"
    },
    {
      "type": "text",
      "id": "top_button_text",
      "label": "Top Right Button Text",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "top_button_link",
      "label": "Top Right Button Link"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "bottom_text",
      "label": "Bottom Strip Text",
      "default": "SUSTAINABLE, ETHICALLY MADE ACTIVEWEAR"
    }
  ],
  "presets": [
    {
      "name": "Gift Guide Banner"
    }
  ]
}
{% endschema %}