<div class="tisso-gift-bar" id="gift-bar-{{ section.id }}">
  <div class="bar-container">
    
    <button type="button" class="bar-toggle" aria-label="Toggle Navigation">
      <div class="hamburger-icon">
        <span></span>
        <span></span>
        <span></span>
      </div>
    </button>

    <div class="bar-brand">
      {% if section.settings.brand_image != blank %}
        <img src="{{ section.settings.brand_image | img_url: 'master' }}" alt="{{ shop.name }}" class="brand-img-element base-layer">
        <img src="{{ section.settings.brand_image | img_url: 'master' }}" alt="{{ shop.name }}" class="brand-img-element overlay-layer">
      {% else %}
        <span style="font-size: 16px; font-weight: bold; letter-spacing: 1px;">UPLOAD LOGO</span>
      {% endif %}
    </div>
 <p class="bar-message bar-message-phn">{{ section.settings.message_text }}</p>
        <a href="{{ section.settings.btn_link }}" class="bar-btn bar-btn-phn">
          {{ section.settings.btn_text }}
          <svg class="arrow-icon" viewBox="0 0 24 24" width="20" height="20">
            <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
    <div class="bar-overlay-panel">
      <div class="panel-inner">
        <p class="bar-message">{{ section.settings.message_text }}</p>
        <a href="{{ section.settings.btn_link }}" class="bar-btn">
          {{ section.settings.btn_text }}
          <svg class="arrow-icon" viewBox="0 0 24 24" width="20" height="20">
            <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

  </div>
</div>

<section
  class="gift-guide-banner"
  style="
    --desktop-bg:url('{{ section.settings.desktop_bg | image_url: width: 2500 }}');
    --mobile-bg:url('{{ section.settings.mobile_bg | image_url: width: 1000 }}');
  "
>
  <div class="gift-guide-banner__content ">
    <div class="gift-banner-content-wraper">
      {% if section.settings.heading != blank %}
        <h2 class="gift-guide-banner__heading">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="gift-guide-banner__description">
          {{ section.settings.description }}
        </div>
      {% endif %}
    </div>
    {% if section.settings.button_text != blank %}
      <a
        href="{{ section.settings.button_link }}"
        class="gift-guide-banner__button"
      >
        {{ section.settings.button_text }}
        <span>→</span>
      </a>
    {% endif %}
  </div>

  <div class="gift-guide-banner__bottom-strip">
    {{ section.settings.bottom_text }}
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const wrapper = document.getElementById('gift-bar-{{ section.id }}');
  const toggleBtn = wrapper.querySelector('.bar-toggle');
  
  if (toggleBtn) {
    toggleBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      
      if (wrapper.classList.contains('is-active')) {
        // Menu close ho rha h: .is-closing lagao reverse animation ke liye
        wrapper.classList.remove('is-active');
        wrapper.classList.add('is-closing');
        
        // Animation khatam hote hi closing class hta do
        setTimeout(() => {
          wrapper.classList.remove('is-closing');
        }, 650);
      } else {
        // Menu open ho rha h
        wrapper.classList.remove('is-closing');
        wrapper.classList.add('is-active');
      }
    });
  }

  document.addEventListener('click', function(e) {
    if (!wrapper.contains(e.target) && wrapper.classList.contains('is-active')) {
      wrapper.classList.remove('is-active');
      wrapper.classList.add('is-closing');
      setTimeout(() => {
        wrapper.classList.remove('is-closing');
      }, 650);
    }
  });
});
</script>

<style>
  /* ========================================== */
  /* DESKTOP CORE STYLES                        */
  /* ========================================== */
  .tisso-gift-bar {
    background-color: #f6f6f6;
    border-bottom: 1px solid #e2e2e2;
    position: relative;
    font-family: "Futura", "Helvetica Neue", Helvetica, Arial, sans-serif;
    z-index: 9999;
    width: 100%;
  }
 
  .bar-container {
    max-width: 100%;
    height: 75px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .bar-toggle {
    display: none;
  }
  .bar-brand {
    display: flex;
    align-items: center;
    position: relative;
  }
  .brand-img-element {
    max-height: 28px;
    width: auto;
    display: block;
    object-fit: contain;
  }
  .overlay-layer {
    display: none !important;
  }
  
  .bar-overlay-panel {
    display: none;
    align-items: center;
    flex: 1;
    justify-content: space-between;
  }
  .panel-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    margin-left: 60px;
  }
  .bar-message {
    font-size: 14px;
    color: #1c1c1c;
    margin: 0;
    font-weight: 400;
    letter-spacing: 0.2px;
  }
  .bar-btn {
     position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14px 40px;
  background: #FFF544;
  color: #000;
  text-decoration: none;
  overflow: hidden;
  z-index: 1;
  transition: color .35s ease;
  }
  .bar-btn:before{
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 0%;
  height: 100%;
  background: #000;
  transition: width .35s ease;
  z-index: -1;
}

.bar-btn:hover::before{
  width: 100%;
}
  .bar-btn:hover {  color: #fff; }
  .arrow-icon { display: inline-block; transition: transform 0.15s ease; }
  .bar-btn:hover .arrow-icon { transform: translateX(3px); }

  /* ========================================== */
  /* MOBILE BREAKPOINT TARGET                   */
  /* ========================================== */
  @media screen and (max-width: 989px) {
    .bar-container {
      height: 65px;
      padding: 0 20px;
      position: relative;
    }
    .bar-message-phn,
    .bar-btn-phn{
    display:none;}
    .bar-toggle {
      display: flex;
      background: none;
      border: none;
      cursor: pointer;
      padding: 10px 10px 10px 0;
      z-index: 10001;
    }
    .hamburger-icon {
      width: 22px;
      height: 14px;
      position: relative;
    }
    .hamburger-icon span {
      display: block;
      position: absolute;
      height: 2px;
      width: 100%;
      background: #000000;
      transition: all 0.25s ease-in-out;
    }
    .hamburger-icon span:nth-child(1) { top: 0; }
    .hamburger-icon span:nth-child(2) { top: 6px; }
    .hamburger-icon span:nth-child(3) { top: 12px; }

    .is-active .hamburger-icon span:nth-child(1) { top: 6px; transform: rotate(45deg); }
    .is-active .hamburger-icon span:nth-child(2) { opacity: 0; }
    .is-active .hamburger-icon span:nth-child(3) { top: 6px; transform: rotate(-45deg); }

    .bar-brand {
      position: absolute;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      pointer-events: none;
      z-index: 10000;
      width: auto;
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* Standard Default Positions */
    .base-layer {
      position: relative;
      opacity: 1;
      transform: translateX(0);
      transition: transform 0.65s cubic-bezier(0.25, 1, 0.5, 1);
    }
    
    .overlay-layer {
      display: block !important;
      position: absolute;
      opacity: 0;
      transform: translateX(6px);
      pointer-events: none;
      transition: transform 0.65s cubic-bezier(0.25, 1, 0.5, 1);
    }

    /* ========================================== */
    /* OPEN ANIMATION STATE (Right to Left)       */
    /* ========================================== */
    .is-active .base-layer {
      transform: translateX(-4px);
    }
    
    .is-active .overlay-layer {
      transform: translateX(-4px);
      animation: clearOverlayOnActive 0.65s cubic-bezier(0.25, 1, 0.5, 1) forwards;
    }

    @keyframes clearOverlayOnActive {
      0% { opacity: 0.4; }
      75% { opacity: 0.15; }
      100% { opacity: 0; }
    }

    /* ========================================== */
    /* CLOSE ANIMATION STATE (Left to Right Mirror)*/
    /* ========================================== */
    .is-closing .base-layer {
      transform: translateX(0); /* Base layer smoothly left to right center aayi */
    }

    .is-closing .overlay-layer {
      transform: translateX(6px); /* Overlay clone wapas right side shift hua */
      animation: clearOverlayOnClosing 0.65s cubic-bezier(0.25, 1, 0.5, 1) forwards;
    }

    @keyframes clearOverlayOnClosing {
      0% { opacity: 0; transform: translateX(-4px); }
      30% { opacity: 0.3; }
      100% { opacity: 0; transform: translateX(6px); }
    }

    /* Dropdown Overlay Panel */
    .bar-overlay-panel {
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      background-color: #f6f6f6;
      border-bottom: 1px solid #e2e2e2;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
      display: block;
      transform: translateY(-15px);
      opacity: 0;
      visibility: hidden;
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
    }
    .is-active .bar-overlay-panel {
      transform: translateY(0);
      opacity: 1;
      visibility: visible;
      display:block;
    }
    .panel-inner {
      flex-direction: column;
      max-width: 100%;
      margin-left: 0;
      padding: 24px 20px 32px 20px;
      text-align: center;
      gap: 20px;
    }
    .bar-message {
      font-size: 16px;
      text-align: center;
    }
    .bar-btn {
      width: 100%;
      box-sizing: border-box;
      padding: 14px 45px;
    }
  }

  .gift-guide-banner{
    position:relative;
    min-height:820px;
    background-image:var(--desktop-bg);
    background-size:cover;
    background-position:left;
    background-repeat:no-repeat;
    display:flex;
    flex-direction:column;
  }

  .gift-guide-banner__content {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      max-width: 600px;
      align-items: flex-start;
      padding: 0px 32px;
      padding-bottom: 60px;
  }

  .gift-guide-banner__heading{
    font-size:70px;
    line-height:1;
    font-weight:500;
    margin:0 0 15px;
  }

  .gift-guide-banner__description{
    max-width:500px;
    font-size:20px;
    line-height:1.2;
    margin-bottom:32px;
  }

  .gift-guide-banner__button {
      width: max-content;
      background: #000;
      color: #fff;
      text-decoration: none;
      padding: 11px 49px;
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight: 400;
      font-size: 16px;
  }

  .gift-guide-banner__bottom-strip{
    background:#F5F5F5;
    text-align:center;
    padding:10px;
    font-size:16px;
    font-weight:400;
    text-transform:uppercase;
    letter-spacing:.08em;
  }


  @media screen and (max-width: 749px){

    .gift-guide-banner{
      min-height: 620px;
      background-image: var(--mobile-bg);
      background-position: center bottom;
    }

    .gift-guide-banner__content{
      padding: 40px 24px;
      align-items: center;
      text-align: center;
      justify-content: space-between;
      max-width: 100%;
    }

    .gift-guide-banner__heading{
      font-size: 30px;
      line-height: 1.1;
      margin: 25px 0 15px 0;
      font-weight: 600;
    }

    .gift-guide-banner__description{
      font-size: 16px;
      line-height: 1.4;
      margin-bottom: 25px;
      max-width: 100%;
      padding: 0 10px;
    }

    .gift-guide-banner__button {
      width: 80%;
             max-width: 193px;
          justify-content: center;
          padding: 9px 30px;
      font-size: 15px;
      letter-spacing: 0.05em;
    }

    .gift-guide-banner__bottom-strip {
      font-size: 13px;
      padding: 12px 10px;
      letter-spacing: 0.06em;
       white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis
    }
  }
</style>

{% schema %}
{
  "name": "Tisso Gift Section",
  "settings": [
    { "type": "image_picker", "id": "brand_image", "label": "Select Logo Image" },
    { "type": "text", "id": "message_text", "label": "Message Text", "default": "Find the ideal gift for your loved ones." },
    { "type": "text", "id": "btn_text", "label": "Button Label", "default": "CHOOSE GIFT" },
    { "type": "url", "id": "btn_link", "label": "Button Link" },
    {
      "type": "image_picker",
      "id": "desktop_bg",
      "label": "Desktop Background Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_bg",
      "label": "Mobile Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "bottom_text",
      "label": "Bottom Strip Text",
      "default": "SUSTAINABLE, ETHICALLY MADE ACTIVEWEAR"
    }
  ],
  "presets": [
    {
      "name": "Tisso Gift Section"
    }
  ]
}
{% endschema %}
